<Window x:Class="OmenSuperHub.Views.TrayPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" Topmost="True"
        ShowInTaskbar="False" ShowActivated="False"
        Focusable="False" SizeToContent="WidthAndHeight"
        SnapsToDevicePixels="True">

  <Border CornerRadius="8" Padding="0"
          Background="{DynamicResource ContextMenuBackground}"
          BorderBrush="{DynamicResource ContextMenuBorderBrush}"
          BorderThickness="1">
    <Border.Effect>
      <DropShadowEffect BlurRadius="24" Direction="270"
                        Opacity="0.18" ShadowDepth="8"
                        Color="#000000"/>
    </Border.Effect>
    <StackPanel>
      <!-- ── Header: preset / performance mode ── -->
      <Grid Margin="14,10,14,8">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <ui:SymbolIcon Grid.Column="0" Symbol="Gauge24" FontSize="16"
                       VerticalAlignment="Center" Margin="0,0,8,0"
                       Foreground="{DynamicResource AccentOmenBrush}"/>
        <StackPanel Grid.Column="1" VerticalAlignment="Center">
          <TextBlock Text="OMEN X HUB" FontSize="9" FontWeight="SemiBold"
                     Opacity="0.55"
                     Foreground="{DynamicResource ContextMenuForeground}"/>
          <TextBlock x:Name="PresetText" FontSize="13" FontWeight="SemiBold"
                     Foreground="{DynamicResource ContextMenuForeground}"
                     Margin="0,1,0,0"
                     FontFamily="Microsoft YaHei UI, Segoe UI"/>
        </StackPanel>
      </Grid>

      <!-- ── Divider ── -->
      <Border Height="1" Margin="14,0,14,0"
              Background="{DynamicResource ContextMenuBorderBrush}" Opacity="0.6"/>

      <!-- ── Metric rows ── -->
      <StackPanel x:Name="MetricPanel" Margin="14,8,14,10"/>
    </StackPanel>
  </Border>
</Window>
