<Window x:Class="OmenSuperHub.Views.TrayPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Width="280"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" Topmost="True"
        ShowInTaskbar="False" ShowActivated="False"
        Focusable="False" SizeToContent="Height"
        SnapsToDevicePixels="True">
  <Window.Resources>
    <SolidColorBrush x:Key="IconAccentBrush" Color="{DynamicResource AccentOmen}"/>
  </Window.Resources>

  <Border CornerRadius="8"
          Background="{DynamicResource ContextMenuBackground}"
          BorderBrush="{DynamicResource BorderDefaultBrush}"
          BorderThickness="1">
    <Border.Effect>
      <DropShadowEffect BlurRadius="32" Direction="270"
                        Opacity="0.28" ShadowDepth="8"
                        Color="#000000"/>
    </Border.Effect>

    <StackPanel>

      <!-- ── Header ── -->
      <TextBlock Text="OMEN X HUB"
                 FontSize="11" FontWeight="SemiBold"
                 Margin="16,14,16,0"
                 Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
      <TextBlock x:Name="PresetText"
                 FontSize="15" FontWeight="SemiBold"
                 Margin="16,2,16,0"
                 Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                 FontFamily="Microsoft YaHei UI, Segoe UI"/>

      <!-- ── Divider ── -->
      <Border Height="1" Margin="16,12,16,0"
              Background="{DynamicResource ControlElevationBorderBrush}"/>

      <!-- ── Metrics Grid ── -->
      <Grid Margin="16,12,16,14">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Performance Mode -->
        <ui:SymbolIcon Grid.Row="0" Grid.Column="0"
                       Symbol="Gauge24" FontSize="20"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource IconAccentBrush}"/>
        <TextBlock Grid.Row="0" Grid.Column="1"
                   x:Name="PerfModeLabel"
                   FontSize="13" FontWeight="Medium"
                   VerticalAlignment="Center"
                   Margin="10,0,0,0"
                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
        <TextBlock x:Name="PresetValueText"
                   Grid.Row="0" Grid.Column="2"
                   FontSize="13"
                   VerticalAlignment="Center"
                   Margin="12,0,0,0"
                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

        <!-- CPU -->
        <ui:SymbolIcon x:Name="CpuIcon"
                       Grid.Row="1" Grid.Column="0"
                       Symbol="DeveloperBoard24" FontSize="20"
                       VerticalAlignment="Center" Margin="0,8,0,0"
                       Foreground="{StaticResource IconAccentBrush}"/>
        <TextBlock x:Name="CpuLabel"
                   Grid.Row="1" Grid.Column="1"
                   Text="CPU"
                   FontSize="13" FontWeight="Medium"
                   VerticalAlignment="Center"
                   Margin="10,8,0,0"
                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
        <TextBlock x:Name="CpuValueText"
                   Grid.Row="1" Grid.Column="2"
                   FontSize="13"
                   VerticalAlignment="Center"
                   Margin="12,8,0,0"
                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

        <!-- GPU -->
        <ui:SymbolIcon x:Name="GpuIcon"
                       Grid.Row="2" Grid.Column="0"
                       Symbol="Video24" FontSize="20"
                       VerticalAlignment="Center" Margin="0,8,0,0"
                       Foreground="{StaticResource IconAccentBrush}"/>
        <TextBlock x:Name="GpuLabel"
                   Grid.Row="2" Grid.Column="1"
                   Text="GPU"
                   FontSize="13" FontWeight="Medium"
                   VerticalAlignment="Center"
                   Margin="10,8,0,0"
                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
        <TextBlock x:Name="GpuValueText"
                   Grid.Row="2" Grid.Column="2"
                   FontSize="13"
                   VerticalAlignment="Center"
                   Margin="12,8,0,0"
                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

        <!-- Fan -->
        <ui:SymbolIcon x:Name="FanIcon"
                       Grid.Row="3" Grid.Column="0"
                       Symbol="Pulse24" FontSize="20"
                       VerticalAlignment="Center" Margin="0,8,0,0"
                       Foreground="{StaticResource IconAccentBrush}"/>
        <TextBlock x:Name="FanLabelText"
                   Grid.Row="3" Grid.Column="1"
                   FontSize="13" FontWeight="Medium"
                   VerticalAlignment="Center"
                   Margin="10,8,0,0"
                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
        <TextBlock x:Name="FanValueText"
                   Grid.Row="3" Grid.Column="2"
                   FontSize="13"
                   VerticalAlignment="Center"
                   Margin="12,8,0,0"
                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

      </Grid>
    </StackPanel>
  </Border>
</Window>
