<ui:FluentWindow x:Class="OmenSuperHub.Views.PipelineEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:app="clr-namespace:OmenSuperHub"
        Title="{x:Static app:Strings.AutomationEditPipeline}" Width="560" Height="600"
        MinWidth="500" MinHeight="400"
        WindowStartupLocation="CenterOwner" ResizeMode="CanMinimize"
        ShowInTaskbar="False"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        Background="Transparent">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Title area -->
    <Border Grid.Row="0"
            BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,0,0,1"
            Padding="16,12">
      <TextBlock x:Name="DialogTitle" Text="{x:Static app:Strings.AutomationEditPipeline}"
                 FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
    </Border>

    <!-- Scrollable content -->
    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                  Margin="12,8,12,0">
      <StackPanel Margin="0,0,0,12">

        <!-- Pipeline Name Card -->
        <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="6" Padding="12,14,12,14" Margin="0,0,0,8">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{x:Static app:Strings.AutomationPipelineName}"
                       FontSize="13" VerticalAlignment="Center"/>
            <TextBox x:Name="NameBox" Grid.Column="1" Height="38" MinWidth="220"
                     FontSize="14" VerticalContentAlignment="Center"/>
          </Grid>
        </Border>

        <!-- Triggers -->
        <Grid Margin="0,4,0,4">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBlock x:Name="TriggersHeading" FontSize="14" FontWeight="SemiBold"
                     VerticalAlignment="Center"/>
          <Button x:Name="AddTriggerBtn" Grid.Column="1" MinWidth="90" Height="28"
                  Padding="8,0" FontSize="11" Click="AddTriggerBtn_Click"/>
        </Grid>

        <StackPanel x:Name="TriggersPanel" Margin="0,0,0,4"/>

        <!-- Steps -->
        <Grid Margin="0,8,0,4">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBlock x:Name="StepsHeading" FontSize="14" FontWeight="SemiBold"
                     VerticalAlignment="Center"/>
          <Button x:Name="AddStepBtn" Grid.Column="1" MinWidth="90" Height="28"
                  Padding="8,0" FontSize="11" Click="AddStepBtn_Click"/>
        </Grid>

        <StackPanel x:Name="StepsPanel" Margin="0,0,0,4"/>

      </StackPanel>
    </ScrollViewer>

    <!-- Button bar -->
    <Border Grid.Row="2"
            BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,1,0,0"
            Padding="16,8">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button x:Name="SaveBtn" MinWidth="90" Height="30"
                Margin="0,0,8,0" Padding="16,4" Click="SaveBtn_Click"/>
        <Button x:Name="CancelBtn" MinWidth="90" Height="30"
                Padding="16,4" Click="CancelBtn_Click"/>
      </StackPanel>
    </Border>

  </Grid>
</ui:FluentWindow>
