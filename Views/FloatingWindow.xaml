<Window x:Class="OmenSuperHub.Views.FloatingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" Topmost="True"
        ShowInTaskbar="False" ShowActivated="False"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        Left="0" Top="0">

  <Grid Background="Transparent" MouseLeftButtonDown="ContentBorder_MouseLeftButtonDown">
    <Border x:Name="ContentBorder" CornerRadius="8" Padding="14,10"
            Background="{DynamicResource BgElevatedBrush}"
            BorderBrush="{DynamicResource BorderDefaultBrush}"
            BorderThickness="1">
      <Border.Effect>
        <DropShadowEffect BlurRadius="12" ShadowDepth="2" Direction="270"
                          Color="#60000000" Opacity="0.4"/>
      </Border.Effect>
    </Border>

    <StackPanel x:Name="DataPanel" Margin="14,10">
      <!-- CPU Row -->
      <WrapPanel x:Name="CpuRow" Margin="0,2">
        <TextBlock Text="CPU" FontFamily="Consolas, Microsoft YaHei UI"
                   FontWeight="ExtraBold" Foreground="{DynamicResource AccentOmenBrush}" VerticalAlignment="Center"
                   x:Name="CpuLabel">
          <TextBlock.Effect><DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="1" Opacity="0.6"/></TextBlock.Effect>
        </TextBlock>
        <TextBlock x:Name="CpuTempText" FontFamily="Consolas"
                   FontWeight="ExtraBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="8,0,0,0"
                   VerticalAlignment="Center">
          <TextBlock.Effect><DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="1" Opacity="0.6"/></TextBlock.Effect>
        </TextBlock>
        <TextBlock x:Name="CpuPowerText" FontFamily="Consolas"
                   FontWeight="ExtraBold"
                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="8,0,0,0"
                   VerticalAlignment="Center">
          <TextBlock.Effect><DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="1" Opacity="0.6"/></TextBlock.Effect>
        </TextBlock>
      </WrapPanel>

      <!-- GPU Row -->
      <WrapPanel x:Name="GpuRow" Margin="0,2">
        <TextBlock Text="GPU" FontFamily="Consolas, Microsoft YaHei UI"
                   FontWeight="ExtraBold" Foreground="{DynamicResource AccentOmenBrush}" VerticalAlignment="Center"
                   x:Name="GpuLabel">
          <TextBlock.Effect><DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="1" Opacity="0.6"/></TextBlock.Effect>
        </TextBlock>
        <TextBlock x:Name="GpuTempText" FontFamily="Consolas"
                   FontWeight="ExtraBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="8,0,0,0"
                   VerticalAlignment="Center">
          <TextBlock.Effect><DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="1" Opacity="0.6"/></TextBlock.Effect>
        </TextBlock>
        <TextBlock x:Name="GpuPowerText" FontFamily="Consolas"
                   FontWeight="ExtraBold"
                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="8,0,0,0"
                   VerticalAlignment="Center">
          <TextBlock.Effect><DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="1" Opacity="0.6"/></TextBlock.Effect>
        </TextBlock>
      </WrapPanel>

      <!-- Fan Row -->
      <WrapPanel x:Name="FanRow" Margin="0,2">
        <TextBlock Text="FAN" FontFamily="Consolas, Microsoft YaHei UI"
                   FontWeight="ExtraBold" Foreground="{DynamicResource AccentOmenBrush}" VerticalAlignment="Center"
                   x:Name="FanLabel">
          <TextBlock.Effect><DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="1" Opacity="0.6"/></TextBlock.Effect>
        </TextBlock>
        <TextBlock x:Name="FanSpeedText" FontFamily="Consolas"
                   FontWeight="ExtraBold"
                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="8,0,0,0"
                   VerticalAlignment="Center">
          <TextBlock.Effect><DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="1" Opacity="0.6"/></TextBlock.Effect>
        </TextBlock>
      </WrapPanel>
    </StackPanel>
  </Grid>
</Window>
