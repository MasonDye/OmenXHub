<local:BaseWindow
    x:Class="OmenSuperHub.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:OmenSuperHub.Windows"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:app="clr-namespace:OmenSuperHub"
    xmlns:pages="clr-namespace:OmenSuperHub.Pages"
    Title="OMEN X Hub"
    Width="1150"
    Height="750"
    MinWidth="650"
    MinHeight="600"
    WindowStartupLocation="CenterScreen"
    ResizeMode="CanResize"
    Topmost="True"
    WindowBackdropType="Mica"
    Background="Transparent"
    ExtendsContentIntoTitleBar="True">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- 自定义背景层 -->
    <Image x:Name="CustomBgImage" Stretch="UniformToFill" Visibility="Collapsed"
           RenderOptions.BitmapScalingMode="HighQuality"
           Grid.RowSpan="2"/>

    <!-- TitleBar -->
    <ui:TitleBar Grid.Row="0" Title="OMEN X Hub" ShowMaximize="True" ShowMinimize="True" ShowClose="True"
                 Background="{DynamicResource NavigationViewExpandedPaneBackgroundBrush}">
      <ui:TitleBar.Header>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <ui:SymbolIcon x:Name="NavIcon" Symbol="Home24" Margin="0,0,6,0" FontSize="14"/>
          <TextBlock x:Name="TitleText" VerticalAlignment="Center" FontSize="12"
                     IsHitTestVisible="False" Text="OMEN X Hub" Opacity="0.8"/>
          <ui:Badge x:Name="DeviceInfoBadge" Margin="8,0,0,0" Appearance="Transparent"
                     Cursor="Hand" MouseLeftButtonDown="DeviceInfoBadge_Click"
                     Visibility="Collapsed"/>
          <ui:Badge x:Name="LogBadge" Margin="8,0,0,0" Appearance="Caution"
                     Cursor="Hand" MouseLeftButtonDown="LogBadge_Click"
                     Visibility="Collapsed" Content="Log"/>
        </StackPanel>
      </ui:TitleBar.Header>
      <ui:TitleBar.TrailingContent>
        <ui:Button x:Name="PinButton" Appearance="Transparent" Width="34" Height="34"
                   ToolTip="取消顶置" Margin="0,0,4,0" Padding="0"
                   Click="PinToggle_Click">
          <ui:SymbolIcon x:Name="PinIcon" Symbol="Pin24" FontSize="14" Margin="2"/>
        </ui:Button>
      </ui:TitleBar.TrailingContent>
    </ui:TitleBar>

    <!-- Content Area -->
    <Grid Grid.Row="1" Margin="0">

      <!-- Navigation (compact icon-only, Lenovo-style) -->
      <ui:NavigationView x:Name="NavigationView"
                          PaneDisplayMode="Left" OpenPaneLength="80" CompactPaneLength="80"
                          IsBackButtonVisible="Collapsed" IsPaneToggleVisible="False"
                          Padding="0" Margin="0"
                          FrameMargin="16,8,8,8"
                          ItemTemplate="{StaticResource OmenNavItemTemplate}"
                          Navigated="NavigationView_Navigated">
        <ui:NavigationView.Background>
          <SolidColorBrush Color="{DynamicResource BgPane}"/>
        </ui:NavigationView.Background>
        <ui:NavigationView.PaneHeader>
          <StackPanel Margin="0,16,0,16" HorizontalAlignment="Center">
            <Viewbox Width="40" Height="40">
              <Canvas Width="100" Height="100">
                <Canvas.Resources>
                  <LinearGradientBrush x:Key="Grad" StartPoint="0,0.79232" EndPoint="0.97998,0.39421">
                    <GradientStop Color="#FF55E1" Offset="0.0"/>
                    <GradientStop Color="#FF0402" Offset="0.46078"/>
                    <GradientStop Color="#FFB402" Offset="1.0"/>
                  </LinearGradientBrush>
                </Canvas.Resources>
                <Path x:Name="DefaultLogoPath" Fill="{DynamicResource Grad}" Data="M 3 47 L 50 3 L 97 47 L 70 47 L 50 30 L 30 47 Z"/>
                <Path Fill="{DynamicResource Grad}" Data="M 3 53 L 50 97 L 97 53 L 70 53 L 50 70 L 30 53 Z"/>
              </Canvas>
            </Viewbox>
            <Image x:Name="CustomLogoImage" Width="40" Height="40" Stretch="UniformToFill" Visibility="Collapsed" Margin="0,-40,0,0"/>
          </StackPanel>
        </ui:NavigationView.PaneHeader>

        <ui:NavigationView.MenuItems>
          <ui:NavigationViewItem x:Name="NavDashboard" TargetPageType="pages:DashboardPage" TargetPageTag="Dashboard"
                                 MinWidth="80" MaxWidth="100" MinHeight="60" Margin="0" Padding="0"
                                 Content="{x:Static app:Strings.SidebarDashboard}">
            <ui:NavigationViewItem.Icon><ui:SymbolIcon Symbol="Home24" FontSize="28" HorizontalAlignment="Center"/></ui:NavigationViewItem.Icon>
          </ui:NavigationViewItem>
          <ui:NavigationViewItem x:Name="NavFan" TargetPageType="pages:FanPage" TargetPageTag="Fan"
                                 MinWidth="80" MaxWidth="100" MinHeight="60" Margin="0" Padding="0"
                                 Content="{x:Static app:Strings.SidebarFan}">
            <ui:NavigationViewItem.Icon><ui:SymbolIcon Symbol="ArrowSync24" FontSize="28" HorizontalAlignment="Center"/></ui:NavigationViewItem.Icon>
          </ui:NavigationViewItem>
          <ui:NavigationViewItem x:Name="NavPerf" TargetPageType="pages:PerfPage" TargetPageTag="Perf"
                                 MinWidth="80" MaxWidth="100" MinHeight="60" Margin="0" Padding="0"
                                 Content="{x:Static app:Strings.SidebarPerf}">
            <ui:NavigationViewItem.Icon><ui:SymbolIcon Symbol="Gauge24" FontSize="28" HorizontalAlignment="Center"/></ui:NavigationViewItem.Icon>
          </ui:NavigationViewItem>
          <ui:NavigationViewItem x:Name="NavLighting" TargetPageType="pages:LightingPage" TargetPageTag="Lighting"
                                 MinWidth="80" MaxWidth="100" MinHeight="60" Margin="0" Padding="0"
                                 Content="{x:Static app:Strings.SidebarLighting}">
            <ui:NavigationViewItem.Icon><ui:SymbolIcon Symbol="Lightbulb24" FontSize="28" HorizontalAlignment="Center"/></ui:NavigationViewItem.Icon>
          </ui:NavigationViewItem>
          <ui:NavigationViewItem x:Name="NavAutomation" TargetPageType="pages:AutomationPage" TargetPageTag="Automation"
                                 MinWidth="80" MaxWidth="100" MinHeight="60" Margin="0" Padding="0"
                                 Content="{x:Static app:Strings.SidebarAutomation}">
            <ui:NavigationViewItem.Icon><ui:SymbolIcon Symbol="Rocket24" FontSize="28" HorizontalAlignment="Center"/></ui:NavigationViewItem.Icon>
          </ui:NavigationViewItem>
          <ui:NavigationViewItem x:Name="NavMacro" TargetPageType="pages:MacroPage" TargetPageTag="Macro"
                                 MinWidth="80" MaxWidth="100" MinHeight="60" Margin="0" Padding="0"
                                 Content="{x:Static app:Strings.SidebarMacro}">
            <ui:NavigationViewItem.Icon><ui:SymbolIcon Symbol="Keyboard24" FontSize="28" HorizontalAlignment="Center"/></ui:NavigationViewItem.Icon>
          </ui:NavigationViewItem>
          <ui:NavigationViewItem x:Name="NavOther" TargetPageType="pages:OtherPage" TargetPageTag="Other"
                                 MinWidth="80" MaxWidth="100" MinHeight="60" Margin="0" Padding="0"
                                 Content="{x:Static app:Strings.SidebarOther}">
            <ui:NavigationViewItem.Icon><ui:SymbolIcon Symbol="MoreHorizontal24" FontSize="28" HorizontalAlignment="Center"/></ui:NavigationViewItem.Icon>
          </ui:NavigationViewItem>
          <ui:NavigationViewItem x:Name="NavSettings" TargetPageType="pages:SettingsPage" TargetPageTag="Settings"
                                 MinWidth="80" MaxWidth="100" MinHeight="60" Margin="0" Padding="0"
                                 Content="{x:Static app:Strings.SidebarSettings}">
            <ui:NavigationViewItem.Icon><ui:SymbolIcon Symbol="Settings24" FontSize="28" HorizontalAlignment="Center"/></ui:NavigationViewItem.Icon>
          </ui:NavigationViewItem>
        </ui:NavigationView.MenuItems>

        <ui:NavigationView.PaneFooter>
          <StackPanel Margin="4,0,4,14">
            <TextBlock x:Name="StatusBarText" FontSize="11"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap" TextAlignment="Center"/>
          </StackPanel>
        </ui:NavigationView.PaneFooter>
      </ui:NavigationView>

    </Grid>
  </Grid>
</local:BaseWindow>
