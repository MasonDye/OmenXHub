<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style x:Key="OmenSlider" TargetType="Slider">
    <Setter Property="Minimum" Value="0"/>
    <Setter Property="Maximum" Value="100"/>
    <Setter Property="Height" Value="24"/>
    <Setter Property="IsSnapToTickEnabled" Value="False"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Slider">
          <Grid VerticalAlignment="Center">
            <Border Height="4" CornerRadius="2">
              <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                  <GradientStop Color="#FF55E1" Offset="0.0"/>
                  <GradientStop Color="#FF0402" Offset="0.5"/>
                  <GradientStop Color="#FFB402" Offset="1.0"/>
                </LinearGradientBrush>
              </Border.Background>
            </Border>
            <Track x:Name="PART_Track">
              <Track.Thumb>
                <Thumb>
                  <Thumb.Style>
                    <Style TargetType="Thumb">
                      <Setter Property="Width" Value="16"/>
                      <Setter Property="Height" Value="16"/>
                      <Setter Property="Template">
                        <Setter.Value>
                          <ControlTemplate TargetType="Thumb">
                            <Ellipse x:Name="ThumbEllipse" Width="12" Height="12"
                                     Fill="Transparent" Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="2"
                                     RenderTransformOrigin="0.5,0.5">
                              <Ellipse.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                              </Ellipse.RenderTransform>
                            </Ellipse>
                            <ControlTemplate.Triggers>
                              <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                  <BeginStoryboard>
                                    <Storyboard>
                                      <DoubleAnimation Storyboard.TargetName="ThumbEllipse" Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.35" Duration="0:0:0.167" EasingFunction="{StaticResource DefaultEase}"/>
                                      <DoubleAnimation Storyboard.TargetName="ThumbEllipse" Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.35" Duration="0:0:0.167" EasingFunction="{StaticResource DefaultEase}"/>
                                    </Storyboard>
                                  </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                  <BeginStoryboard>
                                    <Storyboard>
                                      <DoubleAnimation Storyboard.TargetName="ThumbEllipse" Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" Duration="0:0:0.167" EasingFunction="{StaticResource DefaultEase}"/>
                                      <DoubleAnimation Storyboard.TargetName="ThumbEllipse" Storyboard.TargetProperty="RenderTransform.ScaleY" To="1" Duration="0:0:0.167" EasingFunction="{StaticResource DefaultEase}"/>
                                    </Storyboard>
                                  </BeginStoryboard>
                                </Trigger.ExitActions>
                                <Setter TargetName="ThumbEllipse" Property="Stroke" Value="{DynamicResource AccentOmenBrush}"/>
                              </Trigger>
                            </ControlTemplate.Triggers>
                          </ControlTemplate>
                        </Setter.Value>
                      </Setter>
                    </Style>
                  </Thumb.Style>
                </Thumb>
              </Track.Thumb>
            </Track>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

</ResourceDictionary>