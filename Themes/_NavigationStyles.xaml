<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

  <!-- NavigationView ItemTemplate override: icon centered above text, text hidden when active -->
  <ControlTemplate x:Key="OmenNavItemTemplate" TargetType="{x:Type ui:NavigationViewItem}">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>
      <Border x:Name="MainBorder" Grid.Row="0" Grid.RowSpan="2"
              Padding="4" HorizontalAlignment="Stretch"
              Background="Transparent" BorderBrush="Transparent"
              BorderThickness="1" CornerRadius="6">
        <Grid>
          <Rectangle x:Name="ActiveBar" Width="4" Height="20"
                     Margin="-2,0,0,0" HorizontalAlignment="Left"
                     VerticalAlignment="Center" Opacity="0"
                     RadiusX="2" RadiusY="2"
                      Fill="{DynamicResource SystemAccentColorSecondaryBrush}"/>
          <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <ContentPresenter x:Name="IconPresenter"
                              Content="{TemplateBinding Icon}" Margin="0,6,0,0"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              TextElement.Foreground="{DynamicResource NavigationViewItemForeground}"/>
            <Grid x:Name="ContentGrid" Margin="0,2,0,6">
              <TextBlock FontSize="10" FontWeight="SemiBold"
                         Text="{TemplateBinding Content}"
                         TextAlignment="Center" TextWrapping="Wrap"
                         TextElement.Foreground="{DynamicResource NavigationViewItemForeground}"/>
            </Grid>
          </StackPanel>
        </Grid>
      </Border>
    </Grid>
    <ControlTemplate.Triggers>
      <Trigger Property="IsActive" Value="True">
        <Setter TargetName="ActiveBar" Property="Opacity" Value="1"/>
        <Setter TargetName="ContentGrid" Property="Visibility" Value="Collapsed"/>
        <Setter TargetName="MainBorder" Property="Background">
          <Setter.Value>
            <SolidColorBrush Color="{DynamicResource ControlFillColorDefault}"/>
          </Setter.Value>
        </Setter>
        <Setter TargetName="IconPresenter" Property="TextElement.Foreground">
          <Setter.Value>
            <SolidColorBrush Color="{DynamicResource SystemAccentColorSecondary}"/>
          </Setter.Value>
        </Setter>
      </Trigger>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="IsMouseOver" Value="True"/>
          <Condition Property="IsActive" Value="False"/>
        </MultiTrigger.Conditions>
        <MultiTrigger.Setters>
          <Setter TargetName="MainBorder" Property="Background">
            <Setter.Value>
              <SolidColorBrush Opacity="0.5" Color="{DynamicResource ControlFillColorDefault}"/>
            </Setter.Value>
          </Setter>
          <Setter TargetName="IconPresenter" Property="TextElement.Foreground">
            <Setter.Value>
              <SolidColorBrush Color="{DynamicResource TextFillColorPrimary}"/>
            </Setter.Value>
          </Setter>
          <Setter TargetName="ContentGrid" Property="TextElement.Foreground">
            <Setter.Value>
              <SolidColorBrush Color="{DynamicResource TextFillColorPrimary}"/>
            </Setter.Value>
          </Setter>
        </MultiTrigger.Setters>
      </MultiTrigger>
    </ControlTemplate.Triggers>
  </ControlTemplate>

</ResourceDictionary>
