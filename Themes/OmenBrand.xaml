<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

  <!-- WPF UI Accent Color Mapping → Omen White Accent -->
  <sys:Double x:Key="SystemAccentColorDark1">4286578542</sys:Double>
  <sys:Double x:Key="SystemAccentColorDark2">4286578542</sys:Double>
  <sys:Double x:Key="SystemAccentColorDark3">4286578542</sys:Double>
  <sys:Double x:Key="SystemAccentColorLight1">4293984240</sys:Double>
  <sys:Double x:Key="SystemAccentColorLight2">4293984240</sys:Double>
  <sys:Double x:Key="SystemAccentColorLight3">4293984240</sys:Double>

  <!-- Map WPF UI semantic brushes to Omen color scheme -->
  <!-- Background -->
  <SolidColorBrush x:Key="ApplicationBackgroundBrush" Color="{DynamicResource BgDeep}"/>
  <SolidColorBrush x:Key="ApplicationBackgroundAltBrush" Color="{DynamicResource BgPrimary}"/>
  <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{DynamicResource BgDeep}"/>
  <SolidColorBrush x:Key="LayerFillColorDefaultBrush" Color="{DynamicResource BgCard}"/>
  <SolidColorBrush x:Key="LayerFillColorAltBrush" Color="{DynamicResource BgElevated}"/>
  <SolidColorBrush x:Key="LayerFillColorSecondaryBrush" Color="{DynamicResource ControlFillSecondary}"/>
  <SolidColorBrush x:Key="LayerFillColorTertiaryBrush" Color="{DynamicResource BgCard}"/>
  <SolidColorBrush x:Key="LayerFillColorTranslucentBrush" Color="{DynamicResource LayerFillColorTranslucent}"/>

  <!-- Card / Surface -->
  <!-- CardControl/CardAction/CardExpander use these non-suffixed keys as DynamicResource -->
  <SolidColorBrush x:Key="CardBackground" Color="{DynamicResource BgCard}"/>
  <SolidColorBrush x:Key="CardBorderBrush" Color="{DynamicResource BorderDefault}"/>
  <SolidColorBrush x:Key="CardForeground" Color="{DynamicResource TextPrimary}"/>
  <SolidColorBrush x:Key="CardBackgroundPointerOver" Color="{DynamicResource BgHover}"/>
  <SolidColorBrush x:Key="CardBackgroundPressed" Color="{DynamicResource ControlFillDefault}"/>
  <SolidColorBrush x:Key="CardBackgroundDisabled" Color="{DynamicResource ControlFillDisabled}"/>
  <SolidColorBrush x:Key="CardForegroundPointerOver" Color="{DynamicResource TextPrimary}"/>
  <SolidColorBrush x:Key="CardForegroundPressed" Color="{DynamicResource TextSecondary}"/>
  <SolidColorBrush x:Key="CardForegroundDisabled" Color="{DynamicResource TextDisabled}"/>
  <SolidColorBrush x:Key="CardBorderBrushPressed" Color="{DynamicResource ControlStrokeDefault}"/>
  <SolidColorBrush x:Key="CardBorderBrushDisabled" Color="{DynamicResource ControlStrokeDisabled}"/>
  <SolidColorBrush x:Key="CardFooterBackground" Color="{DynamicResource BgElevated}"/>
  <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="{DynamicResource BgCard}"/>
  <SolidColorBrush x:Key="CardBackgroundFillColorSecondaryBrush" Color="{DynamicResource BgElevated}"/>
  <SolidColorBrush x:Key="CardBackgroundFillColorTertiaryBrush" Color="{DynamicResource BgCard}"/>
  <SolidColorBrush x:Key="CardStrokeColorDefaultBrush" Color="{DynamicResource BorderDefault}"/>
  <SolidColorBrush x:Key="CardStrokeColorSecondaryBrush" Color="{DynamicResource BorderSubtle}"/>
  <SolidColorBrush x:Key="CardBackgroundFillColorQuarternaryBrush" Color="{DynamicResource BgCard}"/>

  <!-- Control Fill -->
  <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="{DynamicResource ControlFillDefault}"/>
  <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="{DynamicResource ControlFillSecondary}"/>
  <SolidColorBrush x:Key="ControlFillColorTertiaryBrush" Color="{DynamicResource ControlFillDefault}"/>
  <SolidColorBrush x:Key="ControlFillColorDisabledBrush" Color="{DynamicResource ControlFillDisabled}"/>
  <SolidColorBrush x:Key="ControlFillColorTransparentBrush" Color="Transparent"/>
  <SolidColorBrush x:Key="ControlStrongFillColorDefaultBrush" Color="{DynamicResource TextPrimary}"/>

  <!-- Control Stroke -->
  <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="{DynamicResource ControlStrokeDefault}"/>
  <SolidColorBrush x:Key="ControlStrokeColorSecondaryBrush" Color="{DynamicResource ControlStrokeSecondary}"/>
  <SolidColorBrush x:Key="ControlStrokeColorOnAccentDefaultBrush" Color="{DynamicResource ControlStrokeColorOnAccentDefault}"/>
  <SolidColorBrush x:Key="ControlStrokeColorOnAccentSecondaryBrush" Color="{DynamicResource ControlStrokeColorOnAccentSecondary}"/>
  <SolidColorBrush x:Key="ControlStrokeColorDisabledBrush" Color="{DynamicResource ControlStrokeDisabled}"/>
  <SolidColorBrush x:Key="ControlStrokeColorStrongBrush" Color="{DynamicResource ControlStrokeDefault}"/>

  <!-- Text -->
  <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="{DynamicResource TextPrimary}"/>
  <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="{DynamicResource TextSecondary}"/>
  <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="{DynamicResource TextTertiary}"/>
  <SolidColorBrush x:Key="TextFillColorDisabledBrush" Color="{DynamicResource TextDisabled}"/>
  <SolidColorBrush x:Key="TextFillColorInverseBrush" Color="{DynamicResource TextOnAccent}"/>
  <SolidColorBrush x:Key="TextFillColorSecondaryMediaBrush" Color="{DynamicResource TextSecondary}"/>
  <SolidColorBrush x:Key="TextFillColorDisabledMediaBrush" Color="{DynamicResource TextDisabled}"/>

  <!-- Accent -->
  <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="{DynamicResource AccentOmen}"/>
  <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="{DynamicResource AccentFillColorSecondary}"/>
  <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="{DynamicResource AccentFillColorTertiary}"/>
  <SolidColorBrush x:Key="AccentFillColorDisabledBrush" Color="{DynamicResource AccentFillColorDisabled}"/>
  <SolidColorBrush x:Key="AccentFillColorSelectedTextBackgroundBrush" Color="{DynamicResource AccentOmen}"/>


  <!-- Divider -->
  <SolidColorBrush x:Key="DividerStrokeColorDefaultBrush" Color="{DynamicResource BorderSubtle}"/>
  <SolidColorBrush x:Key="DividerStrokeColorStrongBrush" Color="{DynamicResource BorderDefault}"/>

  <!-- Info Bar -->
  <SolidColorBrush x:Key="InfoBarInformationalBackgroundBrush" Color="{DynamicResource InfoBarInformationalBackground}"/>
  <SolidColorBrush x:Key="InfoBarSuccessBackgroundBrush" Color="{DynamicResource InfoBarSuccessBackground}"/>
  <SolidColorBrush x:Key="InfoBarWarningBackgroundBrush" Color="{DynamicResource InfoBarWarningBackground}"/>
  <SolidColorBrush x:Key="InfoBarErrorBackgroundBrush" Color="{DynamicResource InfoBarErrorBackground}"/>

  <!-- Navigation — 3-layer Mica transparency: pane > content > cards -->
  <SolidColorBrush x:Key="NavigationViewContentBackground" Color="{DynamicResource BgContent}"/>
  <SolidColorBrush x:Key="NavigationViewContentBackgroundBrush" Color="{DynamicResource BgContent}"/>
  <SolidColorBrush x:Key="NavigationViewContentGridBorderBrush" Color="Transparent"/>
  <SolidColorBrush x:Key="NavigationViewExpandedPaneBackgroundBrush" Color="{DynamicResource BgPane}"/>
  <SolidColorBrush x:Key="NavigationViewItemBackgroundBrush" Color="Transparent"/>
  <SolidColorBrush x:Key="NavigationViewItemBackgroundPointerOverBrush" Color="{DynamicResource BgHover}"/>
  <SolidColorBrush x:Key="NavigationViewItemBackgroundPressedBrush" Color="{DynamicResource BgHover}"/>
  <SolidColorBrush x:Key="NavigationViewItemBackgroundSelectedBrush" Color="{DynamicResource BgHover}"/>
  <SolidColorBrush x:Key="NavigationViewItemForegroundBrush" Color="{DynamicResource NavItemForeground}"/>
  <SolidColorBrush x:Key="NavigationViewItemForegroundPointerOverBrush" Color="{DynamicResource NavItemForegroundActive}"/>
  <SolidColorBrush x:Key="NavigationViewItemForegroundPressedBrush" Color="{DynamicResource NavItemForegroundActive}"/>
  <SolidColorBrush x:Key="NavigationViewItemForegroundSelectedBrush" Color="{DynamicResource NavItemForegroundActive}"/>
  <SolidColorBrush x:Key="NavigationViewItemIndicatorBrush" Color="{DynamicResource NavItemIndicator}"/>
  <SolidColorBrush x:Key="NavigationViewItemHeaderForegroundBrush" Color="{DynamicResource TextSecondary}"/>

  <!-- Toggle Switch -->
  <SolidColorBrush x:Key="ToggleSwitchBackgroundBrush" Color="{DynamicResource ToggleFillOff}"/>
  <SolidColorBrush x:Key="ToggleSwitchBackgroundCheckedBrush" Color="{DynamicResource ToggleFillOn}"/>
  <SolidColorBrush x:Key="ToggleSwitchBackgroundDisabledBrush" Color="{DynamicResource ControlFillDisabled}"/>
  <SolidColorBrush x:Key="ToggleSwitchForegroundBrush" Color="{DynamicResource ToggleThumb}"/>
  <SolidColorBrush x:Key="ToggleSwitchForegroundCheckedBrush" Color="{DynamicResource ToggleThumbOn}"/>
  <SolidColorBrush x:Key="ToggleSwitchStrokeColorDefaultBrush" Color="{DynamicResource BorderDefault}"/>
  <SolidColorBrush x:Key="ToggleSwitchStrokeColorCheckedBrush" Color="{DynamicResource AccentOmen}"/>

  <!-- Slider -->
  <SolidColorBrush x:Key="SliderTrackFillBrush" Color="{DynamicResource SliderTrackFill}"/>
  <SolidColorBrush x:Key="SliderTrackFillPointerOverBrush" Color="{DynamicResource SliderTrackFill}"/>
  <SolidColorBrush x:Key="SliderTrackFillPressedBrush" Color="{DynamicResource SliderTrackFill}"/>
  <SolidColorBrush x:Key="SliderTrackFillDisabledBrush" Color="{DynamicResource ControlFillDisabled}"/>
  <SolidColorBrush x:Key="SliderTrackValueFillBrush" Color="{DynamicResource SliderTrackFillOn}"/>
  <SolidColorBrush x:Key="SliderThumbFillBrush" Color="{DynamicResource SliderThumb}"/>
  <SolidColorBrush x:Key="SliderThumbFillPointerOverBrush" Color="{DynamicResource SliderThumb}"/>
  <SolidColorBrush x:Key="SliderThumbFillPressedBrush" Color="{DynamicResource SliderThumb}"/>
  <SolidColorBrush x:Key="SliderThumbFillDisabledBrush" Color="{DynamicResource TextDisabled}"/>

  <!-- Scrollbar -->
  <SolidColorBrush x:Key="ScrollBarButtonBackgroundBrush" Color="Transparent"/>
  <SolidColorBrush x:Key="ScrollBarButtonBackgroundPointerOverBrush" Color="{DynamicResource BgHover}"/>
  <SolidColorBrush x:Key="ScrollBarButtonBackgroundPressedBrush" Color="{DynamicResource BgHover}"/>
  <SolidColorBrush x:Key="ScrollBarThumbFillBrush" Color="{DynamicResource ScrollBarThumb}"/>
  <SolidColorBrush x:Key="ScrollBarThumbFillPointerOverBrush" Color="{DynamicResource ScrollBarThumbPointerOver}"/>
  <SolidColorBrush x:Key="ScrollBarThumbFillPressedBrush" Color="{DynamicResource ScrollBarThumbPointerOver}"/>
  <SolidColorBrush x:Key="ScrollBarThumbFillDisabledBrush" Color="{DynamicResource ControlFillDisabled}"/>

  <!-- ToolTip -->
  <SolidColorBrush x:Key="ToolTipBackgroundBrush" Color="{DynamicResource BgCard}"/>
  <SolidColorBrush x:Key="ToolTipForegroundBrush" Color="{DynamicResource TextPrimary}"/>
  <SolidColorBrush x:Key="ToolTipBorderBrush" Color="{DynamicResource BorderDefault}"/>

  <!-- Menu / Context Menu -->
  <SolidColorBrush x:Key="MenuBackgroundBrush" Color="{DynamicResource BgCard}"/>
  <SolidColorBrush x:Key="MenuForegroundBrush" Color="{DynamicResource TextPrimary}"/>
  <SolidColorBrush x:Key="MenuBorderBrush" Color="{DynamicResource BorderDefault}"/>
  <SolidColorBrush x:Key="MenuItemBackgroundPointerOverBrush" Color="{DynamicResource BgHover}"/>
  <SolidColorBrush x:Key="MenuItemForegroundPointerOverBrush" Color="{DynamicResource TextPrimary}"/>

  <!-- Content Dialog -->
  <SolidColorBrush x:Key="ContentDialogBackgroundBrush" Color="{DynamicResource BgCard}"/>
  <SolidColorBrush x:Key="ContentDialogForegroundBrush" Color="{DynamicResource TextPrimary}"/>
  <SolidColorBrush x:Key="ContentDialogBorderBrush" Color="{DynamicResource BorderDefault}"/>

  <!-- InfoBadge -->
  <SolidColorBrush x:Key="InfoBadgeBackgroundBrush" Color="{DynamicResource AccentOmen}"/>
  <SolidColorBrush x:Key="InfoBadgeForegroundBrush" Color="{DynamicResource TextOnAccent}"/>

  <!-- Hyperlink -->
  <SolidColorBrush x:Key="HyperlinkForegroundBrush" Color="{DynamicResource AccentBlue}"/>
  <SolidColorBrush x:Key="HyperlinkForegroundPointerOverBrush" Color="{DynamicResource AccentBlue}"/>
  <SolidColorBrush x:Key="HyperlinkForegroundPressedBrush" Color="{DynamicResource AccentBlue}"/>

  <!-- Badge -->
  <SolidColorBrush x:Key="BadgeBackgroundBrush" Color="{DynamicResource BadgeDefaultBackground}"/>
  <SolidColorBrush x:Key="BadgeForegroundBrush" Color="{DynamicResource BadgeDefaultForeground}"/>

  <!-- ProgressBar -->
  <SolidColorBrush x:Key="ProgressBarBackgroundBrush" Color="{DynamicResource ControlFillSecondary}"/>
  <SolidColorBrush x:Key="ProgressBarIndicatorBrush" Color="{DynamicResource AccentOmen}"/>

</ResourceDictionary>
