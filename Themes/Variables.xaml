<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- DESIGN TOKENS (WPFUI-inspired)                             -->
  <!-- ═══════════════════════════════════════════════════════════ -->

  <!-- Corner Radius -->
  <CornerRadius x:Key="ControlCornerRadius">4</CornerRadius>
  <CornerRadius x:Key="CardCornerRadius">8</CornerRadius>
  <CornerRadius x:Key="PopupCornerRadius">8</CornerRadius>
  <CornerRadius x:Key="OverlayCornerRadius">6</CornerRadius>
  <CornerRadius x:Key="ToggleCornerRadius">12</CornerRadius>
  <CornerRadius x:Key="BadgeCornerRadius">4</CornerRadius>

  <!-- Spacing / Sizing -->
  <Thickness x:Key="CardPadding">16,14</Thickness>
  <Thickness x:Key="ButtonPadding">16,8</Thickness>
  <Thickness x:Key="SmallButtonPadding">8,4</Thickness>
  <Thickness x:Key="TextPadding">8,4</Thickness>
  <Thickness x:Key="PageMargin">24,20</Thickness>
  <Thickness x:Key="NavItemPadding">14,10</Thickness>
  <Thickness x:Key="CardMargin">0,0,0,8</Thickness>
  <Thickness x:Key="CardContentMargin">0,0,0,12</Thickness>

  <!-- Border Thickness -->
  <Thickness x:Key="DefaultBorderThickness">1</Thickness>
  <Thickness x:Key="ThinBorderThickness">0.5</Thickness>
  <Thickness x:Key="NoBorderThickness">0</Thickness>

  <!-- Min Heights -->
  <sys:Double x:Key="TextControlMinHeight">24</sys:Double>
  <sys:Double x:Key="ButtonMinHeight">32</sys:Double>
  <sys:Double x:Key="SliderMinHeight">24</sys:Double>

  <!-- Animation Durations (ms) -->
  <sys:Double x:Key="ControlFastAnimationDuration">167</sys:Double>
  <sys:Double x:Key="ControlNormalAnimationDuration">250</sys:Double>
  <sys:Double x:Key="ControlSlowAnimationDuration">350</sys:Double>

  <!-- Easing Functions -->
  <QuadraticEase x:Key="DefaultEase" EasingMode="EaseInOut"/>

  <!-- Font Sizes -->
  <sys:Double x:Key="DefaultFontSize">13</sys:Double>
  <sys:Double x:Key="ControlContentThemeFontSize">14</sys:Double>
  <sys:Double x:Key="HeadingFontSize">18</sys:Double>
  <sys:Double x:Key="SubHeadingFontSize">14</sys:Double>
  <sys:Double x:Key="CaptionFontSize">11</sys:Double>
  <sys:Double x:Key="StatValueFontSize">28</sys:Double>
  <sys:Double x:Key="NavIconFontSize">16</sys:Double>

  <!-- Font Families -->
  <FontFamily x:Key="DefaultFontFamily">Microsoft YaHei UI, Segoe UI</FontFamily>
  <FontFamily x:Key="MonoFontFamily">Consolas, Microsoft YaHei UI</FontFamily>
  <FontFamily x:Key="FluentSystemIcons">pack://application:,,,/OmenXHub;component/Resources/Fonts/#FluentSystemIcons-Regular</FontFamily>

</ResourceDictionary>
