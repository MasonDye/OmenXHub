<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ponytail: removed duplicate MenuShadow — kept in _MiscStyles.xaml (used only there) -->

  <Style x:Key="OmenFocusVisual">
    <Setter Property="Control.Template">
      <Setter.Value>
        <ControlTemplate>
          <Border BorderBrush="{DynamicResource BorderFocusBrush}" BorderThickness="1"
                  CornerRadius="4" Margin="1"/>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="DefaultControlFocusVisualStyle">
    <Setter Property="Control.Template">
      <Setter.Value>
        <ControlTemplate>
          <Border BorderBrush="{DynamicResource BorderFocusBrush}" BorderThickness="1"
                  CornerRadius="4" Margin="1"/>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

</ResourceDictionary>