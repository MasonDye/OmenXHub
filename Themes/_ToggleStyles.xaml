<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style x:Key="OmenCheckBox" TargetType="CheckBox">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="FontFamily" Value="{DynamicResource DefaultFontFamily}"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="CheckBox">
          <StackPanel Orientation="Horizontal">
            <Border x:Name="CheckBorder" Width="18" Height="18" CornerRadius="4"
                    Background="{DynamicResource BgInputBrush}"
                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                    BorderThickness="1" VerticalAlignment="Center"
                    SnapsToDevicePixels="True">
              <Path x:Name="CheckPath" Data="M 3 8 L 7 12 L 14 4"
                    Stroke="{DynamicResource AccentOmenBrush}"
                    StrokeThickness="2.5" StrokeLineJoin="Round"
                    Opacity="0" VerticalAlignment="Center"
                    HorizontalAlignment="Center" Margin="0,0,1,0">
                <Path.LayoutTransform>
                  <ScaleTransform ScaleX="0.5" ScaleY="0.5"/>
                </Path.LayoutTransform>
              </Path>
            </Border>
            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"/>
          </StackPanel>
          <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="CheckPath" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.25" EasingFunction="{StaticResource DefaultEase}"/>
                    <DoubleAnimation Storyboard.TargetName="CheckPath" Storyboard.TargetProperty="(Path.LayoutTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.25" EasingFunction="{StaticResource DefaultEase}"/>
                    <DoubleAnimation Storyboard.TargetName="CheckPath" Storyboard.TargetProperty="(Path.LayoutTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.25" EasingFunction="{StaticResource DefaultEase}"/>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="CheckPath" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15" EasingFunction="{StaticResource DefaultEase}"/>
                    <DoubleAnimation Storyboard.TargetName="CheckPath" Storyboard.TargetProperty="(Path.LayoutTransform).(ScaleTransform.ScaleX)" To="0.5" Duration="0:0:0.15" EasingFunction="{StaticResource DefaultEase}"/>
                    <DoubleAnimation Storyboard.TargetName="CheckPath" Storyboard.TargetProperty="(Path.LayoutTransform).(ScaleTransform.ScaleY)" To="0.5" Duration="0:0:0.15" EasingFunction="{StaticResource DefaultEase}"/>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
              <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{DynamicResource AccentOmenBrush}"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{DynamicResource AccentOmenBrush}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="OmenNavButton" TargetType="RadioButton">
    <Setter Property="Foreground" Value="{DynamicResource NavItemForeground}"/>
    <Setter Property="FontFamily" Value="{DynamicResource DefaultFontFamily}"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="GroupName" Value="NavGroup"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="RadioButton">
          <Border x:Name="Bd" Background="Transparent" BorderBrush="Transparent" BorderThickness="1" CornerRadius="6"
                  Padding="15,10" Margin="0,2" SnapsToDevicePixels="True">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <Border x:Name="ActiveIndicator" Grid.Column="0" Width="3" CornerRadius="1.5"
                      HorizontalAlignment="Left" VerticalAlignment="Stretch"
                      Opacity="0" Margin="0,2,0,2">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FF55E1" Offset="0.0"/>
                    <GradientStop Color="#FF0402" Offset="0.5"/>
                    <GradientStop Color="#FFB402" Offset="1.0"/>
                  </LinearGradientBrush>
                </Border.Background>
                <Border.RenderTransform>
                  <TranslateTransform X="-15"/>
                </Border.RenderTransform>
              </Border>
              <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0">
                <TextBlock x:Name="NavIcon" Text="{TemplateBinding Tag}"
                           FontFamily="{DynamicResource FluentSystemIcons}"
                           FontSize="16" VerticalAlignment="Center"
                           Width="20" TextAlignment="Center"
                           Margin="0,0,10,0"
                           Foreground="{TemplateBinding Foreground}"/>
                <ContentPresenter VerticalAlignment="Center"/>
              </StackPanel>
            </Grid>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="ActiveIndicator"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.22"
                                     EasingFunction="{StaticResource DefaultEase}"/>
                    <DoubleAnimation Storyboard.TargetName="ActiveIndicator"
                                     Storyboard.TargetProperty="RenderTransform.X"
                                     From="-15" To="0" Duration="0:0:0.3"
                                     EasingFunction="{StaticResource DefaultEase}"/>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="ActiveIndicator"
                                     Storyboard.TargetProperty="Opacity"
                                     From="1" To="0" Duration="0:0:0.15"
                                     EasingFunction="{StaticResource DefaultEase}"/>
                    <DoubleAnimation Storyboard.TargetName="ActiveIndicator"
                                     Storyboard.TargetProperty="RenderTransform.X"
                                     From="0" To="15" Duration="0:0:0.2"
                                     EasingFunction="{StaticResource DefaultEase}"/>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
              <Setter Property="Foreground" Value="{DynamicResource NavItemForegroundActive}"/>
              <Setter TargetName="Bd" Property="Background" Value="{DynamicResource NavItemBackgroundHover}"/>
              <Setter TargetName="Bd" Property="BorderBrush">
                <Setter.Value>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#FF55E1" Offset="0.0"/>
                    <GradientStop Color="#FF0402" Offset="0.5"/>
                    <GradientStop Color="#FFB402" Offset="1.0"/>
                  </LinearGradientBrush>
                </Setter.Value>
              </Setter>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="{DynamicResource NavItemBackgroundHover}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="OmenOptionRadio" TargetType="RadioButton">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="FontFamily" Value="{DynamicResource DefaultFontFamily}"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Margin" Value="0,2"/>
    <Setter Property="MinWidth" Value="80"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="RadioButton">
          <Grid>
            <Border x:Name="BdHover" Background="{DynamicResource BgHoverBrush}" CornerRadius="6" Opacity="0"/>
            <Border x:Name="BdChecked" Background="{DynamicResource BgHoverBrush}" CornerRadius="6"
                    BorderThickness="1" BorderBrush="{DynamicResource AccentOmenBrush}" Opacity="0"/>
            <Border Padding="14,8" SnapsToDevicePixels="True">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                RecognizesAccessKey="True"/>
            </Border>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="BdChecked" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.167" EasingFunction="{StaticResource DefaultEase}"/>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="BdChecked" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.12" EasingFunction="{StaticResource DefaultEase}"/>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
              <Setter Property="Foreground" Value="{DynamicResource AccentOmenBrush}"/>
              <Setter TargetName="BdChecked" Property="Opacity" Value="1"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="BdHover" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.167" EasingFunction="{StaticResource DefaultEase}"/>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="BdHover" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.167" EasingFunction="{StaticResource DefaultEase}"/>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="OmenToggle" TargetType="ToggleButton">
    <Setter Property="Width" Value="44"/>
    <Setter Property="Height" Value="24"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ToggleButton">
          <Grid x:Name="RootGrid" Width="44" Height="24">
            <Border x:Name="Track" Background="{DynamicResource ToggleFillOff}" CornerRadius="12" Width="44" Height="24"/>
            <Border x:Name="TrackOn" Background="{DynamicResource ToggleFillOn}" CornerRadius="12" Width="44" Height="24" Opacity="0"/>
            <Ellipse x:Name="Thumb" Width="18" Height="18" Fill="{DynamicResource ToggleThumb}"
                     HorizontalAlignment="Left" Margin="3,0,0,0" IsHitTestVisible="False">
              <Ellipse.RenderTransform>
                <TranslateTransform X="0" Y="0"/>
              </Ellipse.RenderTransform>
            </Ellipse>
            <Ellipse x:Name="ThumbOn" Width="18" Height="18" Fill="{DynamicResource ToggleThumbOn}"
                     HorizontalAlignment="Left" Margin="3,0,0,0" Opacity="0" IsHitTestVisible="False">
              <Ellipse.RenderTransform>
                <TranslateTransform X="0" Y="0"/>
              </Ellipse.RenderTransform>
            </Ellipse>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="Track" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.167" EasingFunction="{StaticResource DefaultEase}"/>
                    <DoubleAnimation Storyboard.TargetName="TrackOn" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.167" EasingFunction="{StaticResource DefaultEase}"/>
                    <DoubleAnimation Storyboard.TargetName="Thumb" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.167" EasingFunction="{StaticResource DefaultEase}"/>
                    <DoubleAnimation Storyboard.TargetName="ThumbOn" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.167" EasingFunction="{StaticResource DefaultEase}"/>
                    <DoubleAnimation Storyboard.TargetName="Thumb" Storyboard.TargetProperty="(Ellipse.RenderTransform).(TranslateTransform.X)" To="20" Duration="0:0:0.167" EasingFunction="{StaticResource DefaultEase}"/>
                    <DoubleAnimation Storyboard.TargetName="ThumbOn" Storyboard.TargetProperty="(Ellipse.RenderTransform).(TranslateTransform.X)" To="20" Duration="0:0:0.167" EasingFunction="{StaticResource DefaultEase}"/>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="Track" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.167" EasingFunction="{StaticResource DefaultEase}"/>
                    <DoubleAnimation Storyboard.TargetName="TrackOn" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.167" EasingFunction="{StaticResource DefaultEase}"/>
                    <DoubleAnimation Storyboard.TargetName="Thumb" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.167" EasingFunction="{StaticResource DefaultEase}"/>
                    <DoubleAnimation Storyboard.TargetName="ThumbOn" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.167" EasingFunction="{StaticResource DefaultEase}"/>
                    <DoubleAnimation Storyboard.TargetName="Thumb" Storyboard.TargetProperty="(Ellipse.RenderTransform).(TranslateTransform.X)" To="0" Duration="0:0:0.167" EasingFunction="{StaticResource DefaultEase}"/>
                    <DoubleAnimation Storyboard.TargetName="ThumbOn" Storyboard.TargetProperty="(Ellipse.RenderTransform).(TranslateTransform.X)" To="0" Duration="0:0:0.167" EasingFunction="{StaticResource DefaultEase}"/>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Opacity" Value="0.5"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="OmenToggleButton" TargetType="ToggleButton">
    <Setter Property="Background" Value="{DynamicResource BgElevatedBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="2"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="FontFamily" Value="{DynamicResource DefaultFontFamily}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ToggleButton">
          <Border x:Name="Bd" Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="4" Padding="{TemplateBinding Padding}"
                  SnapsToDevicePixels="True">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHoverBrush}"/>
              <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentOmenBrush}"/>
              <Setter Property="Foreground" Value="{DynamicResource AccentOmenBrush}"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentOmenDimBrush}"/>
              <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentOmenBrush}"/>
              <Setter Property="Foreground" Value="{DynamicResource AccentOmenBrush}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

</ResourceDictionary>