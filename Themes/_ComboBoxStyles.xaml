<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <DropShadowEffect x:Key="MenuShadow" BlurRadius="20" ShadowDepth="4"
                     Direction="270" Color="#80000000" Opacity="0.6"/>

  <Style x:Key="OmenComboBoxItem" TargetType="ComboBoxItem">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="FontFamily" Value="{DynamicResource DefaultFontFamily}"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="Padding" Value="14,10"/>
    <Setter Property="MinHeight" Value="32"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ComboBoxItem">
          <Grid Margin="2,1">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border x:Name="Indicator" Grid.Column="0" Width="3"
                    Background="{DynamicResource AccentOmenBrush}"
                    CornerRadius="1.5" HorizontalAlignment="Left"
                    VerticalAlignment="Stretch" Opacity="0" Margin="0,4,6,4"/>
            <Border x:Name="Bd" Grid.Column="1" Background="Transparent"
                    Padding="{TemplateBinding Padding}"
                    CornerRadius="4" SnapsToDevicePixels="True">
              <ContentPresenter VerticalAlignment="Center"/>
            </Border>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHoverBrush}"/>
              <Setter Property="Foreground" Value="{DynamicResource AccentOmenBrush}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="Indicator"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.167"
                                     EasingFunction="{StaticResource DefaultEase}"/>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="Indicator"
                                     Storyboard.TargetProperty="Opacity"
                                     From="1" To="0" Duration="0:0:0.167"
                                     EasingFunction="{StaticResource DefaultEase}"/>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
              <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHoverBrush}"/>
              <Setter Property="Foreground" Value="{DynamicResource AccentOmenBrush}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="OmenComboBoxToggle" TargetType="ToggleButton">
    <Setter Property="Background" Value="{DynamicResource ControlFillDefaultBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeDefaultBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Focusable" Value="False"/>
    <Setter Property="ClickMode" Value="Press"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ToggleButton">
          <Border x:Name="Bd" Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="6" SnapsToDevicePixels="True">
            <Path x:Name="Arrow" Data="M 0 0 L 5 5 L 10 0 Z"
                  Fill="{DynamicResource TextSecondaryBrush}"
                  HorizontalAlignment="Right" VerticalAlignment="Center"
                  Margin="0,0,12,0" RenderTransformOrigin="0.5,0.5">
              <Path.RenderTransform>
                <RotateTransform Angle="0"/>
              </Path.RenderTransform>
            </Path>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentOmenBrush}"/>
              <Setter TargetName="Arrow" Property="Fill" Value="{DynamicResource AccentOmenBrush}"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="Arrow"
                                     Storyboard.TargetProperty="RenderTransform.Angle"
                                     To="180" Duration="0:0:0.167"
                                     EasingFunction="{StaticResource DefaultEase}"/>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="Arrow"
                                     Storyboard.TargetProperty="RenderTransform.Angle"
                                     To="0" Duration="0:0:0.167"
                                     EasingFunction="{StaticResource DefaultEase}"/>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
              <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentOmenBrush}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="OmenComboBox" TargetType="ComboBox">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="FontFamily" Value="{DynamicResource DefaultFontFamily}"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="ItemContainerStyle" Value="{StaticResource OmenComboBoxItem}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ComboBox">
          <Grid>
             <ToggleButton x:Name="ToggleButton" Style="{DynamicResource OmenComboBoxToggle}"
                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                              Content="{TemplateBinding SelectionBoxItem}"
                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                              Margin="14,10,34,10" VerticalAlignment="Center"
                              HorizontalAlignment="Left"/>
            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
              <Border x:Name="DropDownBorder" Background="{DynamicResource BgCardBrush}"
                      BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1"
                      CornerRadius="6" Padding="2,4" Margin="0,2,0,0"
                      MinWidth="{TemplateBinding ActualWidth}" MaxHeight="300"
                       Effect="{DynamicResource MenuShadow}">
                 <ScrollViewer Style="{DynamicResource OmenScrollViewer}" SnapsToDevicePixels="True">
                  <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                </ScrollViewer>
              </Border>
            </Popup>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="OmenListBox" TargetType="ListBox">
    <Setter Property="Background" Value="{DynamicResource BgCardBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource CardElevationBorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="FontFamily" Value="Consolas, Microsoft YaHei UI, Segoe UI"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
    <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
    <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ListBox">
          <Border x:Name="Bd" Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="6">
             <ScrollViewer Style="{DynamicResource OmenScrollViewer}" Padding="4"
                          Focusable="False">
              <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
            </ScrollViewer>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

</ResourceDictionary>