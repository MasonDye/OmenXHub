<Page x:Class="OmenSuperHub.Pages.FanPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:app="clr-namespace:OmenSuperHub"
      Title="{x:Static app:Strings.PageFan}">
<ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="24,20" TextElement.Foreground="{DynamicResource TextPrimaryBrush}">
      <TextBlock x:Name="HeadingFan" Text="{x:Static app:Strings.FanControl}" FontSize="22" FontWeight="Bold" Margin="0,0,0,16"/>

      <ui:CardControl Margin="{StaticResource CardMargin}">
        <ui:CardControl.Header>
          <StackPanel>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="ArrowSync24" Margin="0,0,8,0"/>
                <TextBlock Text="{x:Static app:Strings.FanConfigHeading}" Tag="FanConfig" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource AccentOmenBrush}" VerticalAlignment="Center"/>
              </StackPanel>
              <ComboBox x:Name="FanModeCombo" Grid.Column="1" MinWidth="140"
                        SelectionChanged="FanMode_SelectionChanged">
                <ComboBoxItem Content="{x:Static app:Strings.FanSilentMode}"/>
                <ComboBoxItem Content="{x:Static app:Strings.FanCoolMode}"/>
                <ComboBoxItem Content="{x:Static app:Strings.FanCustomCurve}"/>
                <ComboBoxItem Content="智能风扇"/>
                <ComboBoxItem Content="{x:Static app:Strings.FanManualMode}"/>
              </ComboBox>
            </Grid>
          </StackPanel>
        </ui:CardControl.Header>
      </ui:CardControl>

      <ui:CardControl x:Name="ManualControlCard" Margin="{StaticResource CardMargin}" Visibility="Collapsed">
        <ui:CardControl.Header>
          <StackPanel>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="ArrowSync24" Margin="0,0,6,0"/>
                <TextBlock Text="{x:Static app:Strings.FanSpeedRPM}" FontWeight="SemiBold" VerticalAlignment="Center"/>
              </StackPanel>
              <WrapPanel Grid.Column="1">
                <ToggleButton x:Name="FanRpmExpand" Width="24" Height="24" Padding="0" Margin="0,0,8,0"
                              VerticalAlignment="Top"
                              Checked="FanRpmExpand_Changed" Unchecked="FanRpmExpand_Changed">
                  <ui:SymbolIcon Symbol="ChevronDown24" FontSize="12"/>
                </ToggleButton>
                <ComboBox x:Name="FanRpmCombo" MinWidth="100" Margin="0,0,0,0"
                          SelectionChanged="FanRpmCombo_SelectionChanged"/>
              </WrapPanel>
            </Grid>
            <StackPanel x:Name="FanRpmExtra" Visibility="Collapsed" Margin="0,6,0,0">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Slider x:Name="FanRpmSlider" Minimum="500" Maximum="6000" Value="2500"
                        TickFrequency="100" IsSnapToTickEnabled="True" 
                        ValueChanged="FanRpmSlider_Changed"/>
                <TextBlock x:Name="FanRpmSliderVal" Grid.Column="1" Text="2500 RPM" Width="64"
                           TextAlignment="Right" VerticalAlignment="Center" FontSize="12" Margin="4,0,0,0"/>
                <TextBox x:Name="FanRpmInput" Grid.Column="2" Width="80" Height="34" Margin="8,0,0,0"/>
                <Button x:Name="FanRpmApply" Grid.Column="3" Width="32" Height="34" Padding="0" Margin="4,0,0,0"
                        Click="FanRpmApply_Click">
                  <ui:SymbolIcon Symbol="Checkmark24" FontSize="12"/>
                </Button>
              </Grid>
              <TextBlock x:Name="FanRpmError" Visibility="Collapsed" Foreground="{DynamicResource AccentRedBrush}" Margin="0,2,0,0" FontSize="11"/>
            </StackPanel>
          </StackPanel>
        </ui:CardControl.Header>
      </ui:CardControl>


      <ui:CardControl x:Name="FanCurveCard" Margin="{StaticResource CardMargin}" Visibility="Collapsed">
        <ui:CardControl.Header>
          <StackPanel>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Edit24" Margin="0,0,8,0"/>
                <TextBlock Text="{x:Static app:Strings.FanCurveHeading}" Tag="SelfDefineCurve" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource AccentOmenBrush}" VerticalAlignment="Center"/>
              </StackPanel>
              <ComboBox x:Name="FanCurveSel" Grid.Column="1" MinWidth="120"
                        SelectedIndex="0" SelectionChanged="FanCurveSel_Changed">
                <ComboBoxItem Content="{x:Static app:Strings.FanCurveCPULabel}"/>
                <ComboBoxItem Content="{x:Static app:Strings.FanCurveGPULabel}"/>
              </ComboBox>
            </Grid>
            <StackPanel Margin="0,12,0,12">
              <TextBlock x:Name="FanCurveTipText" Text="{x:Static app:Strings.FanCurveTip}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
              <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Text="可右键创建或删除控制点"/>
            </StackPanel>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="45"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <StackPanel Grid.Row="0" Grid.Column="0" VerticalAlignment="Top" Margin="0,0,0,24">
                <TextBlock Text="RPM" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
              </StackPanel>
              <Border Grid.Row="0" Grid.Column="1" Margin="0,0,10,24" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="4">
                <Canvas x:Name="FanCurveCanvas" Height="260" Background="Transparent"
                        MouseLeftButtonDown="FanCurveCanvas_MouseLeftButtonDown"
                        MouseMove="FanCurveCanvas_MouseMove"
                        MouseLeftButtonUp="FanCurveCanvas_MouseLeftButtonUp"
                        MouseRightButtonDown="FanCurveCanvas_MouseRightButtonDown"/>
              </Border>
              <TextBlock Grid.Row="1" Grid.Column="1" x:Name="CurveAxisLabel" Text="{x:Static app:Strings.TempCelsius}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,10,0"/>
            </Grid>
          </StackPanel>
        </ui:CardControl.Header>
      </ui:CardControl>

      <ui:CardControl x:Name="SmartFanCard" Margin="{StaticResource CardMargin}" Visibility="Collapsed">
        <ui:CardControl.Header>
          <StackPanel>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Bot24" Margin="0,0,8,0"/>
                <TextBlock Text="智能风扇" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource AccentOmenBrush}" VerticalAlignment="Center"/>
              </StackPanel>
              <ComboBox x:Name="SmartCurvePreset" Grid.Column="1" MinWidth="120" SelectionChanged="SmartCurvePreset_Changed">
                <ComboBoxItem Content="均衡"/>
                <ComboBoxItem Content="静音"/>
                <ComboBoxItem Content="高性能"/>
              </ComboBox>
            </Grid>
            <Grid Margin="0,8,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <StackPanel Grid.Row="0" Grid.Column="0">
                <TextBlock Text="平报警数" FontSize="12" VerticalAlignment="Center"/>
                <TextBlock Text="值越小响应越灵敏" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
              </StackPanel>
              <ComboBox x:Name="SmartEmaAlphaCombo" Grid.Row="0" Grid.Column="1" MinWidth="100" SelectionChanged="SmartEmaAlpha_Changed">
                <ComboBoxItem Content="0.1 (快)"/>
                <ComboBoxItem Content="0.3 (中)" IsSelected="True"/>
                <ComboBoxItem Content="0.5 (慢)"/>
              </ComboBox>
              <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,6,0,0">
                <TextBlock Text="降速速率" FontSize="12" VerticalAlignment="Center"/>
                <TextBlock Text="每秒最多下降 RPM" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
              </StackPanel>
              <ComboBox x:Name="SmartStepDownCombo" Grid.Row="1" Grid.Column="1" MinWidth="100" Margin="0,6,0,0" SelectionChanged="SmartStepDown_Changed">
                <ComboBoxItem Content="100"/>
                <ComboBoxItem Content="300"/>
                <ComboBoxItem Content="500" IsSelected="True"/>
                <ComboBoxItem Content="1000"/>
              </ComboBox>
              <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,6,0,0">
                <TextBlock Text="滞后阈值" FontSize="12" VerticalAlignment="Center"/>
                <TextBlock Text="温度变化阈值(°C)" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
              </StackPanel>
              <ComboBox x:Name="SmartHysteresisCombo" Grid.Row="2" Grid.Column="1" MinWidth="100" Margin="0,6,0,0" SelectionChanged="SmartHysteresis_Changed">
                <ComboBoxItem Content="0.2"/>
                <ComboBoxItem Content="0.5" IsSelected="True"/>
                <ComboBoxItem Content="1.0"/>
              </ComboBox>
            </Grid>
          </StackPanel>
        </ui:CardControl.Header>
      </ui:CardControl>

      <ui:CardControl Margin="0,0,0,0">
        <ui:CardControl.Header>
          <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
              <ui:SymbolIcon Symbol="Settings24" FontSize="18" Margin="0,0,8,0"/>
              <TextBlock Text="{x:Static app:Strings.FanSettings}" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel x:Name="TempSensCard" Margin="0,8,0,8">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{x:Static app:Strings.TempSensitivityHeading}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                <ComboBox x:Name="SensitivityCombo" Grid.Column="1" MinWidth="140"
                          SelectionChanged="Sensitivity_SelectionChanged">
                  <ComboBoxItem Content="{x:Static app:Strings.FanRespRealtime}"/>
                  <ComboBoxItem Content="{x:Static app:Strings.FanRespHigh}"/>
                  <ComboBoxItem Content="{x:Static app:Strings.FanRespMedium}"/>
                  <ComboBoxItem Content="{x:Static app:Strings.FanRespLow}"/>
                </ComboBox>
              </Grid>
            </StackPanel>
            <Grid Margin="{StaticResource CardMargin}">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="{x:Static app:Strings.FanAutoProtect}" FontSize="12" VerticalAlignment="Center"/>
                <TextBlock Text="{x:Static app:Strings.AutoFanProtectDesc}" FontSize="11"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
              </StackPanel>
              <ui:ToggleSwitch x:Name="AutoFanProtectToggle" Grid.Column="1"
                              Checked="AutoFanProtectToggle_Changed" Unchecked="AutoFanProtectToggle_Changed"/>
            </Grid>
            <Grid Margin="0,6,0,6">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="{x:Static app:Strings.FanSync}" FontSize="12" VerticalAlignment="Center"/>
                <TextBlock Text="{x:Static app:Strings.FanSyncDesc}" FontSize="11"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
              </StackPanel>
              <ui:ToggleSwitch x:Name="FanSyncToggle" Grid.Column="1"
                              Checked="FanSyncToggle_Changed" Unchecked="FanSyncToggle_Changed"/>
            </Grid>
            <Grid x:Name="CleanCreekCard" Visibility="Collapsed">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="{x:Static app:Strings.CleanCreekHeading}" FontSize="12" VerticalAlignment="Center"/>
                <TextBlock x:Name="CleanCreekDesc" Text="{x:Static app:Strings.DustCleanDesc}" FontSize="11"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
              </StackPanel>
              <Button x:Name="CleanCreekBtn" Grid.Column="1"
                      Content="{x:Static app:Strings.CleanCreekStartBtn}" Width="140" Height="34" Click="CleanCreekBtn_Click"/>
            </Grid>
          </StackPanel>
        </ui:CardControl.Header>
      </ui:CardControl>
    </StackPanel>
  </ScrollViewer>
</Page>
