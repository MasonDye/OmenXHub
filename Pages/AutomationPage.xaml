<Page x:Class="OmenSuperHub.Pages.AutomationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:app="clr-namespace:OmenSuperHub"
      Title="{x:Static app:Strings.PageAutomation}">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="24,20" TextElement.Foreground="{DynamicResource TextPrimaryBrush}">
      <TextBlock x:Name="HeadingAutomation" Text="{x:Static app:Strings.AutomationHeading}" Tag="AutomationHeading" FontSize="22" FontWeight="Bold" Margin="0,0,0,20"/>

      <!-- ══════ 1. 主开关卡片 ══════ -->
      <ui:CardControl Margin="0,0,0,8">
        <ui:CardControl.Header>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
              <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Settings24" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
	                <TextBlock Text="{x:Static app:Strings.AutoEnableHeading}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
	              </StackPanel>
	              <TextBlock Text="{x:Static app:Strings.AutoEnableDesc}" FontSize="11"
                         Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
            </StackPanel>
            <ui:ToggleSwitch x:Name="AutoEnableToggle" Grid.Column="1" VerticalAlignment="Center"
                            Checked="AutoEnableToggle_Checked" Unchecked="AutoEnableToggle_Unchecked"/>
          </Grid>
        </ui:CardControl.Header>
      </ui:CardControl>

      <!-- ══════ 2. 自动化列表区域（无卡片） ══════ -->
      <StackPanel Margin="0,0,0,0">
        <!-- 动态管道列表 -->
        <StackPanel x:Name="AutoPipelineList"/>
        <!-- 空状态 / 操作按钮 -->
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="1" HorizontalAlignment="Right">
		            <TextBlock x:Name="AutoNoPipelines"
			                       Text="{x:Static app:Strings.AutoNoPipelinesText}"
			                       FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
			                       Margin="0,8,16,8" HorizontalAlignment="Right" TextAlignment="Right" Visibility="Visible"/>
		            <Button x:Name="AutoAddPipelineBtn" Content="{x:Static app:Strings.AutoAddNew}" MinWidth="100" Height="30"
                    HorizontalAlignment="Right"
                    ToolTip="{x:Static app:Strings.AutoAddDisabledTooltip}"
                    Click="AutoAddPipeline_Click"/>
          </StackPanel>
        </Grid>
      </StackPanel>

      <!-- ══════ 3. 快捷操作区域 ══════ -->
      <StackPanel Margin="0,24,0,0">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <StackPanel VerticalAlignment="Top">
            <StackPanel Orientation="Horizontal">
              <ui:SymbolIcon Symbol="DeviceEq24" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
              <TextBlock x:Name="AutoQuickActionsText" Text="{x:Static app:Strings.AutomationQuickActions}"
                         FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
	            <TextBlock Text="{x:Static app:Strings.AutoQuickActionsDesc}" FontSize="11"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,4,0,0"/>
          </StackPanel>
          <StackPanel Grid.Column="1" HorizontalAlignment="Right">
	            <TextBlock x:Name="AutoNoQuickActions"
			                       Text="{x:Static app:Strings.AutoNoQuickActionsText}"
			                       FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
			                       Margin="0,0,16,8" HorizontalAlignment="Right" TextAlignment="Right" Visibility="Visible"/>
		            <Button x:Name="AutoAddQuickActionBtn" Content="{x:Static app:Strings.AutoAddNew}" MinWidth="100" Height="30"
                    HorizontalAlignment="Right"
                    ToolTip="{x:Static app:Strings.AutoAddDisabledTooltip}"
                    Click="AutoAddQuickAction_Click"/>
          </StackPanel>
        </Grid>
        <WrapPanel x:Name="AutoQuickActionPanel" Margin="0,8,0,0"/>
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</Page>
