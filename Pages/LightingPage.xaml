<Page x:Class="OmenSuperHub.Pages.LightingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:app="clr-namespace:OmenSuperHub"
      Title="{x:Static app:Strings.PageLighting}"
      SizeChanged="LightingPage_SizeChanged">

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="24,20" TextElement.Foreground="{DynamicResource TextPrimaryBrush}">
      <TextBlock x:Name="HeadingLighting" Text="{x:Static app:Strings.LightingControl}" FontSize="22" FontWeight="Bold" Margin="0,0,0,16"/>

      <Grid x:Name="LightGrid">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" x:Name="LightCol0"/>
          <ColumnDefinition Width="12" x:Name="LightColGap"/>
          <ColumnDefinition Width="*" x:Name="LightCol1"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="8"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="8"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="8"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <VisualStateManager.VisualStateGroups>
          <VisualStateGroup x:Name="LightLayoutStates">
            <!-- ponytail: Wide = 2 列 2 行;Narrow = 单列 4 行。.cs SizeChanged 调用 GoToState
                 精确切换(避免 WrapPanel 物理换行临界闪烁 + 左右间距不均)。
                 Narrow 下:第 2 列宽=0 + 间距列宽=0,4 张卡走 Grid.Row 0/2/4/6 同列。 -->
            <VisualState x:Name="Wide"/>
            <VisualState x:Name="Narrow">
              <Storyboard>
                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="LightCol1"
                                               Storyboard.TargetProperty="(ColumnDefinition.Width)">
                  <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static GridLength.Auto}"/>
                </ObjectAnimationUsingKeyFrames>
                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="LightColGap"
                                               Storyboard.TargetProperty="(ColumnDefinition.Width)">
                  <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static GridLength.Auto}"/>
                </ObjectAnimationUsingKeyFrames>
                <!-- ponytail: Narrow 下把右侧 2 张卡换到 Column 0,Row 2/4(避开 0/2 的左侧卡)。
                     Grid.Row/Grid.Column 是 attached property,DiscreteObjectKeyFrame 用 Int32 即可。 -->
                <Int32AnimationUsingKeyFrames Storyboard.TargetName="LightCard1"
                                              Storyboard.TargetProperty="(Grid.Row)">
                  <DiscreteInt32KeyFrame KeyTime="0" Value="2"/>
                </Int32AnimationUsingKeyFrames>
                <Int32AnimationUsingKeyFrames Storyboard.TargetName="LightCard1"
                                              Storyboard.TargetProperty="(Grid.Column)">
                  <DiscreteInt32KeyFrame KeyTime="0" Value="0"/>
                </Int32AnimationUsingKeyFrames>
                <Int32AnimationUsingKeyFrames Storyboard.TargetName="LightCard3"
                                              Storyboard.TargetProperty="(Grid.Row)">
                  <DiscreteInt32KeyFrame KeyTime="0" Value="6"/>
                </Int32AnimationUsingKeyFrames>
                <Int32AnimationUsingKeyFrames Storyboard.TargetName="LightCard3"
                                              Storyboard.TargetProperty="(Grid.Column)">
                  <DiscreteInt32KeyFrame KeyTime="0" Value="0"/>
                </Int32AnimationUsingKeyFrames>
              </Storyboard>
            </VisualState>
          </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <ui:CardControl x:Name="LightCard0" Grid.Row="0" Grid.Column="0" Margin="0,0,0,8">
          <ui:CardControl.Header>
            <StackPanel>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <ui:SymbolIcon Symbol="DeviceEq24" FontSize="18" Margin="0,0,10,0"/>
                <TextBlock x:Name="LightDeviceText" Text="{x:Static app:Strings.LightingDeviceHeading}" Tag="Device" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource AccentOmenBrush}" VerticalAlignment="Center"/>
              </StackPanel>
              <ComboBox x:Name="LightDevCombo" MinWidth="120"
                        SelectionChanged="LightDev_SelectionChanged">
                <ComboBoxItem Content="{x:Static app:Strings.LightingKeyboard}"/>
                <ComboBoxItem Content="{x:Static app:Strings.LightingLightBar}"/>
              </ComboBox>
            </StackPanel>
          </ui:CardControl.Header>
        </ui:CardControl>

        <ui:CardControl x:Name="LightCard1" Grid.Row="0" Grid.Column="2" Margin="0,0,0,8">
          <ui:CardControl.Header>
            <StackPanel>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <ui:SymbolIcon Symbol="Settings24" FontSize="18" Margin="0,0,10,0"/>
                <TextBlock x:Name="LightProtocolText" Text="{x:Static app:Strings.LightingProtocolHeading}" Tag="Protocol" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource AccentOmenBrush}" VerticalAlignment="Center"/>
              </StackPanel>
              <ComboBox x:Name="LightProtoCombo" MinWidth="120"
                        SelectionChanged="LightProto_SelectionChanged">
                <ComboBoxItem Content="{x:Static app:Strings.LightingProtoBasic}"/>
                <ComboBoxItem Content="{x:Static app:Strings.LightingProtoDojo}"/>
                <ComboBoxItem Content="HP SDK" Tag="HpSdk"/>
                <!-- ponytail: Added in this pass. Selecting PerKey shows the PerKey RGB card below -->
                <ComboBoxItem Content="{x:Static app:Strings.LightingPerKeyTitle}" Tag="PerKey"/>
              </ComboBox>
            </StackPanel>
          </ui:CardControl.Header>
        </ui:CardControl>

        <ui:CardControl x:Name="LightCard2" Grid.Row="2" Grid.Column="0" Margin="0,0,0,8">
          <ui:CardControl.Header>
            <StackPanel>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <ui:SymbolIcon Symbol="Lightbulb24" FontSize="18" Margin="0,0,10,0"/>
                <TextBlock Text="{x:Static app:Strings.LightingBrightSpeed}" FontWeight="SemiBold" VerticalAlignment="Center"/>
              </StackPanel>
              <TextBlock Text="{x:Static app:Strings.LightingBrightness}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Slider x:Name="LightBrightSlider" Minimum="0" Maximum="100" Value="100"

                        ValueChanged="LightBright_Changed"/>
                <TextBlock x:Name="LightBrightVal" Grid.Column="1" Width="40" Text="100%"
                           FontSize="12" VerticalAlignment="Center" TextAlignment="Right"/>
              </Grid>
              <!-- ponytail: Dojo firmware accepts brightness > 100 (228=on per Light Studio reverse).
                   These buttons teleport the slider-equivalent value into the LightingBrightness
                   config underneath; Basic/HP-SDK firmware clips at 100, so they only appear under Dojo.
                   Slider stays 0-100 because > 100 looks broken on the visual range. -->
              <StackPanel x:Name="DojoHighBrightPanel" Orientation="Horizontal" Margin="0,6,0,0" Visibility="Collapsed">
                <Button x:Name="BtnBright128" Content="{x:Static app:Strings.LightingBrightnessHigh}"
                        Click="BtnBrightHigh_Click" Tag="128" Padding="8,2" Margin="0,0,6,0"/>
                <Button x:Name="BtnBright228" Content="{x:Static app:Strings.LightingBrightnessMax}"
                        Click="BtnBrightHigh_Click" Tag="228" Padding="8,2"/>
              </StackPanel>
              <TextBlock Text="{x:Static app:Strings.LightingSpeedHeading}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,8,0,4"/>
              <ComboBox x:Name="AnimSpeedCombo" MinWidth="140">
                <ComboBoxItem Content="{x:Static app:Strings.LightingSpeedSlow}"/>
                <ComboBoxItem Content="{x:Static app:Strings.LightingSpeedMedium}"/>
                <ComboBoxItem Content="{x:Static app:Strings.LightingSpeedFast}"/>
              </ComboBox>
            </StackPanel>
          </ui:CardControl.Header>
        </ui:CardControl>

        <ui:CardControl x:Name="LightCard3" Grid.Row="2" Grid.Column="2" Margin="0,0,0,8">
          <!-- ponytail: Zone 子 Grid 的 VSM 挂在 LightCard3(Control) 上,因为 GoToState 只接受 Control。
               Storyboard TargetName 按名字查可跨层级引用 ZoneColGap/Zone2Cell/Zone4Cell。 -->
          <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="ZoneLayoutStates">
              <VisualState x:Name="Zone2Col"/>
              <VisualState x:Name="Zone1Col">
                <Storyboard>
                  <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ZoneColGap"
                                                 Storyboard.TargetProperty="(ColumnDefinition.Width)">
                    <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static GridLength.Auto}"/>
                  </ObjectAnimationUsingKeyFrames>
                  <Int32AnimationUsingKeyFrames Storyboard.TargetName="Zone2Cell"
                                                Storyboard.TargetProperty="(Grid.Row)">
                    <DiscreteInt32KeyFrame KeyTime="0" Value="2"/>
                  </Int32AnimationUsingKeyFrames>
                  <Int32AnimationUsingKeyFrames Storyboard.TargetName="Zone2Cell"
                                                Storyboard.TargetProperty="(Grid.Column)">
                    <DiscreteInt32KeyFrame KeyTime="0" Value="0"/>
                  </Int32AnimationUsingKeyFrames>
                  <Int32AnimationUsingKeyFrames Storyboard.TargetName="Zone4Cell"
                                                Storyboard.TargetProperty="(Grid.Row)">
                    <DiscreteInt32KeyFrame KeyTime="0" Value="6"/>
                  </Int32AnimationUsingKeyFrames>
                  <Int32AnimationUsingKeyFrames Storyboard.TargetName="Zone4Cell"
                                                Storyboard.TargetProperty="(Grid.Column)">
                    <DiscreteInt32KeyFrame KeyTime="0" Value="0"/>
                  </Int32AnimationUsingKeyFrames>
                </Storyboard>
              </VisualState>
            </VisualStateGroup>
          </VisualStateManager.VisualStateGroups>
          <ui:CardControl.Header>
            <StackPanel>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <ui:SymbolIcon Symbol="Color24" FontSize="18" Margin="0,0,10,0"/>
                <TextBlock Text="{x:Static app:Strings.LightingZoneColorHeading}" FontWeight="SemiBold" VerticalAlignment="Center"/>
              </StackPanel>
              <Grid x:Name="ZoneGrid">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="8" x:Name="ZoneColGap"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="8"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" x:Name="Zone1Cell">
                  <TextBlock x:Name="Zone1Text" Text="{x:Static app:Strings.LightingZone1}" Tag="Zone1" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                  <ComboBox x:Name="Zone1Combo" MinWidth="120"
                            SelectionChanged="ZoneColor_SelectionChanged">
                    <ComboBoxItem Tag="Red" Content="{x:Static app:Strings.LightingColorRed}"/>
                    <ComboBoxItem Tag="Green" Content="{x:Static app:Strings.LightingColorGreen}"/>
                    <ComboBoxItem Tag="Blue" Content="{x:Static app:Strings.LightingColorBlue}"/>
                    <ComboBoxItem Tag="White" Content="{x:Static app:Strings.LightingColorWhite}"/>
                    <ComboBoxItem Tag="Cyan" Content="{x:Static app:Strings.LightingColorCyan}"/>
                    <ComboBoxItem Tag="Pink" Content="{x:Static app:Strings.LightingColorMagenta}"/>
                    <ComboBoxItem Tag="Yellow" Content="{x:Static app:Strings.LightingColorYellow}"/>
                    <ComboBoxItem Tag="Custom" Content="{x:Static app:Strings.LightingCustom}"/>
                  </ComboBox>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2" x:Name="Zone2Cell">
                  <TextBlock x:Name="Zone2Text" Text="{x:Static app:Strings.LightingZone2}" Tag="Zone2" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                  <ComboBox x:Name="Zone2Combo" MinWidth="120"
                            SelectionChanged="ZoneColor_SelectionChanged">
                    <ComboBoxItem Tag="Red" Content="{x:Static app:Strings.LightingColorRed}"/>
                    <ComboBoxItem Tag="Green" Content="{x:Static app:Strings.LightingColorGreen}"/>
                    <ComboBoxItem Tag="Blue" Content="{x:Static app:Strings.LightingColorBlue}"/>
                    <ComboBoxItem Tag="White" Content="{x:Static app:Strings.LightingColorWhite}"/>
                    <ComboBoxItem Tag="Cyan" Content="{x:Static app:Strings.LightingColorCyan}"/>
                    <ComboBoxItem Tag="Pink" Content="{x:Static app:Strings.LightingColorMagenta}"/>
                    <ComboBoxItem Tag="Yellow" Content="{x:Static app:Strings.LightingColorYellow}"/>
                    <ComboBoxItem Tag="Custom" Content="{x:Static app:Strings.LightingCustom}"/>
                  </ComboBox>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="0" x:Name="Zone3Cell">
                  <TextBlock x:Name="Zone3Text" Text="{x:Static app:Strings.LightingZone3}" Tag="Zone3" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                  <ComboBox x:Name="Zone3Combo" MinWidth="120"
                            SelectionChanged="ZoneColor_SelectionChanged">
                    <ComboBoxItem Tag="Red" Content="{x:Static app:Strings.LightingColorRed}"/>
                    <ComboBoxItem Tag="Green" Content="{x:Static app:Strings.LightingColorGreen}"/>
                    <ComboBoxItem Tag="Blue" Content="{x:Static app:Strings.LightingColorBlue}"/>
                    <ComboBoxItem Tag="White" Content="{x:Static app:Strings.LightingColorWhite}"/>
                    <ComboBoxItem Tag="Cyan" Content="{x:Static app:Strings.LightingColorCyan}"/>
                    <ComboBoxItem Tag="Pink" Content="{x:Static app:Strings.LightingColorMagenta}"/>
                    <ComboBoxItem Tag="Yellow" Content="{x:Static app:Strings.LightingColorYellow}"/>
                    <ComboBoxItem Tag="Custom" Content="{x:Static app:Strings.LightingCustom}"/>
                  </ComboBox>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="2" x:Name="Zone4Cell">
                  <TextBlock x:Name="Zone4Text" Text="{x:Static app:Strings.LightingZone4}" Tag="Zone4" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                  <ComboBox x:Name="Zone4Combo" MinWidth="120"
                            SelectionChanged="ZoneColor_SelectionChanged">
                    <ComboBoxItem Tag="Red" Content="{x:Static app:Strings.LightingColorRed}"/>
                    <ComboBoxItem Tag="Green" Content="{x:Static app:Strings.LightingColorGreen}"/>
                    <ComboBoxItem Tag="Blue" Content="{x:Static app:Strings.LightingColorBlue}"/>
                    <ComboBoxItem Tag="White" Content="{x:Static app:Strings.LightingColorWhite}"/>
                    <ComboBoxItem Tag="Cyan" Content="{x:Static app:Strings.LightingColorCyan}"/>
                    <ComboBoxItem Tag="Pink" Content="{x:Static app:Strings.LightingColorMagenta}"/>
                    <ComboBoxItem Tag="Yellow" Content="{x:Static app:Strings.LightingColorYellow}"/>
                    <ComboBoxItem Tag="Custom" Content="{x:Static app:Strings.LightingCustom}"/>
                  </ComboBox>
                </StackPanel>
              </Grid>
            </StackPanel>
          </ui:CardControl.Header>
        </ui:CardControl>
      </Grid>

      <ui:CardControl Margin="{StaticResource CardMargin}">
        <ui:CardControl.Header>
          <StackPanel>
            <StackPanel Orientation="Horizontal">
              <ui:SymbolIcon Symbol="Replay24" FontSize="18" Margin="0,0,10,0"/>
              <TextBlock x:Name="LightAnimText" Text="{x:Static app:Strings.LightingAnimation}" Tag="LightingAnimation" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource AccentOmenBrush}" VerticalAlignment="Center"/>
            </StackPanel>
            <ComboBox x:Name="AnimCombo" MinWidth="180" Margin="0,8,0,0"
                      SelectionChanged="Anim_SelectionChanged">
              <ComboBoxItem Content="{x:Static app:Strings.LightingAnimNone}"/>
              <ComboBoxItem Content="{x:Static app:Strings.LightingAnimColorCycle}"/>
              <ComboBoxItem Content="{x:Static app:Strings.LightingAnimStarlight}"/>
              <ComboBoxItem Content="{x:Static app:Strings.LightingAnimBreathing}"/>
              <ComboBoxItem Content="{x:Static app:Strings.LightingAnimWave}"/>
              <ComboBoxItem Content="{x:Static app:Strings.LightingAnimRaindrop}"/>
              <ComboBoxItem Content="{x:Static app:Strings.LightingAnimAudioPulse}"/>
              <ComboBoxItem Content="{x:Static app:Strings.LightingAnimConfetti}"/>
              <ComboBoxItem Content="{x:Static app:Strings.LightingAnimSun}"/>
              <ComboBoxItem Content="{x:Static app:Strings.LightingAnimSwipe}"/>
            </ComboBox>

            <!-- ponytail: Direction/Theme only forwarded to firmware under Dojo anim; UI
                 keeps them visible but the .cs disables them when the active protocol/anim
                 can't honour them. Strings LightingDirection/LightingTheme + LightingDir*
                 + LightingTheme* were already defined and unused — reused as-is. -->
            <Grid Margin="0,12,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <TextBlock Text="{x:Static app:Strings.LightingDirection}" FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                <ComboBox x:Name="AnimDirCombo" MinWidth="140" IsEnabled="False"
                          SelectionChanged="AnimDir_SelectionChanged">
                  <ComboBoxItem Tag="Left" Content="{x:Static app:Strings.LightingDirLeft}"/>
                  <ComboBoxItem Tag="Right" Content="{x:Static app:Strings.LightingDirRight}"/>
                </ComboBox>
              </StackPanel>
              <StackPanel Grid.Column="1" Margin="8,0,0,0">
                <TextBlock Text="{x:Static app:Strings.LightingTheme}" FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                <ComboBox x:Name="AnimThemeCombo" MinWidth="140" IsEnabled="False"
                          SelectionChanged="AnimTheme_SelectionChanged">
                  <ComboBoxItem Tag="Galaxy" Content="{x:Static app:Strings.LightingThemeGalaxy}"/>
                  <ComboBoxItem Tag="Volcano" Content="{x:Static app:Strings.LightingThemeVolcano}"/>
                  <ComboBoxItem Tag="Jungle" Content="{x:Static app:Strings.LightingThemeJungle}"/>
                  <ComboBoxItem Tag="Ocean" Content="{x:Static app:Strings.LightingThemeOcean}"/>
                  <ComboBoxItem Tag="Custom" Content="{x:Static app:Strings.LightingThemeCustom}"/>
                </ComboBox>
              </StackPanel>
            </Grid>
          </StackPanel>
        </ui:CardControl.Header>
      </ui:CardControl>

      <!-- ponytail: PerKey RGB card — toggled Visible only when keyboard is Rgb or protocol
           is set to PerKey. Reuses already-implemented OmenLighting.OpenPerKeyKeyboard /
           SetPerKeyStaticColor / SetPerKeyAnimation / SetPerKeyBrightness / StorePerKeyToFlash /
           CloseDeviceAsync. HID handle is opened per click (no caching) — keeps the diff small
           and matches the WinForms source's pattern; if it becomes a hot path later, wrap with
           a per-page handle cache. -->
      <ui:CardControl x:Name="PerKeyCard" Visibility="Collapsed" Margin="{StaticResource CardMargin}">
        <ui:CardControl.Header>
          <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
              <ui:SymbolIcon Symbol="Color24" FontSize="18" Margin="0,0,10,0"/>
              <TextBlock Text="{x:Static app:Strings.LightingPerKeyTitle}" Tag="PerKeyRgb"
                         FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource AccentOmenBrush}"
                         VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="{x:Static app:Strings.LightingPerKeyStaticColor}" FontSize="12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
            <ComboBox x:Name="PerKeyStaticCombo" MinWidth="160" Margin="0,0,0,12"
                      SelectionChanged="PerKeyStatic_SelectionChanged">
              <ComboBoxItem Tag="Red" Content="{x:Static app:Strings.LightingColorRed}"/>
              <ComboBoxItem Tag="Green" Content="{x:Static app:Strings.LightingColorGreen}"/>
              <ComboBoxItem Tag="Blue" Content="{x:Static app:Strings.LightingColorBlue}"/>
              <ComboBoxItem Tag="White" Content="{x:Static app:Strings.LightingColorWhite}"/>
              <ComboBoxItem Tag="Cyan" Content="{x:Static app:Strings.LightingColorCyan}"/>
              <ComboBoxItem Tag="Pink" Content="{x:Static app:Strings.LightingColorMagenta}"/>
              <ComboBoxItem Tag="Yellow" Content="{x:Static app:Strings.LightingColorYellow}"/>
            </ComboBox>

            <TextBlock Text="{x:Static app:Strings.LightingPerKeyAnimation}" FontSize="12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
            <ComboBox x:Name="PerKeyAnimCombo" MinWidth="180" Margin="0,0,0,12"
                      SelectionChanged="PerKeyAnim_SelectionChanged">
              <ComboBoxItem Tag="None" Content="{x:Static app:Strings.LightingAnimNone}"/>
              <ComboBoxItem Tag="ColorCycle" Content="{x:Static app:Strings.LightingAnimColorCycle}"/>
              <ComboBoxItem Tag="Starlight" Content="{x:Static app:Strings.LightingAnimStarlight}"/>
              <ComboBoxItem Tag="Breathing" Content="{x:Static app:Strings.LightingAnimBreathing}"/>
              <ComboBoxItem Tag="Wave" Content="{x:Static app:Strings.LightingAnimWave}"/>
              <ComboBoxItem Tag="Raindrop" Content="{x:Static app:Strings.LightingAnimRaindrop}"/>
              <ComboBoxItem Tag="AudioPulse" Content="{x:Static app:Strings.LightingAnimAudioPulse}"/>
              <ComboBoxItem Tag="Confetti" Content="{x:Static app:Strings.LightingAnimConfetti}"/>
              <ComboBoxItem Tag="Sun" Content="{x:Static app:Strings.LightingAnimSun}"/>
              <ComboBoxItem Tag="Swipe" Content="{x:Static app:Strings.LightingAnimSwipe}"/>
            </ComboBox>

            <TextBlock Text="{x:Static app:Strings.LightingPerKeyBrightness}" FontSize="12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <Slider x:Name="PerKeyBrightSlider" Minimum="0" Maximum="100" Value="100"
                      ValueChanged="PerKeyBright_Changed"/>
              <TextBlock x:Name="PerKeyBrightVal" Grid.Column="1" Width="40" Text="100%"
                         FontSize="12" VerticalAlignment="Center" TextAlignment="Right" Margin="6,0,0,0"/>
              <Button x:Name="PerKeyApplyBtn" Grid.Column="2" Content="{x:Static app:Strings.ApplyLightingBtn}"
                      Click="PerKeyApply_Click" Padding="12,4" Margin="8,0,0,0"/>
            </Grid>
            <!-- ponytail: status row backing live updates — shows "Brightness: 50%",
                 "Static Color: Red", "Animation: Wave ✓" or a connect-fail hint so the
                 user sees what's actually applied instead of guessing from inert buttons. -->
            <TextBlock x:Name="PerKeyStatusText" FontSize="11" Margin="0,8,0,0"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
          </StackPanel>
        </ui:CardControl.Header>
      </ui:CardControl>

      <ui:CardControl>
        <ui:CardControl.Header>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="ApplyLightBtn" Grid.Column="1" Content="{x:Static app:Strings.ApplyLightingBtn}"
                    Width="200" Height="40" Click="ApplyLightBtn_Click"/>
          </Grid>
        </ui:CardControl.Header>
      </ui:CardControl>

    </StackPanel>
  </ScrollViewer>
</Page>
