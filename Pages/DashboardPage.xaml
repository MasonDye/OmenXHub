<Page x:Class="OmenSuperHub.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:app="clr-namespace:OmenSuperHub"
      Title="{x:Static app:Strings.PageDashboard}"
      SizeChanged="DashboardPage_SizeChanged">

  <Page.Resources>
    <Style TargetType="ProgressBar">
      <Setter Property="Height" Value="8"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ProgressBar">
            <Grid>
              <Rectangle x:Name="PART_Track" RadiusX="4" RadiusY="4"
                         Fill="{DynamicResource ControlFillSecondaryBrush}"/>
              <Rectangle x:Name="PART_Indicator" RadiusX="4" RadiusY="4"
                         Fill="{TemplateBinding Foreground}" 
                         HorizontalAlignment="Left"/>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Page.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <StackPanel Margin="24,16" MinWidth="400" TextElement.Foreground="{DynamicResource TextPrimaryBrush}">

      <TextBlock Text="{x:Static app:Strings.DashboardHeading}" FontSize="22" FontWeight="Bold" Margin="0,0,0,16"/>

      <Grid x:Name="MetricsGrid" Margin="0,0,0,12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="12"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- CPU -->
        <ui:CardControl Grid.Row="0" Grid.Column="0">
          <ui:CardControl.Header>
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                  <ui:SymbolIcon Symbol="DeveloperBoard24" FontSize="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
                  <TextBlock Text="{x:Static app:Strings.MonitorCpuLabel}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
                <Path x:Name="CpuBrandLogo" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Top"
                      Width="40" Height="40" Margin="0,4,4,0" Opacity="0.06" Stretch="Uniform"
                      IsHitTestVisible="False" Fill="Transparent" Visibility="Collapsed"/>
              </Grid>
              <Border Grid.Row="1" Height="1" Background="{DynamicResource DividerStrokeDefaultBrush}" Margin="0,8,0,6" Opacity="0.3"/>
              <StackPanel x:Name="CpuDetailPanel" Grid.Row="1" Margin="0,8,0,0">
                <Grid Margin="0,0,0,6">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="64"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="{x:Static app:Strings.TempCelsius}" FontSize="11"
                             Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                             VerticalAlignment="Center"/>
                  <ProgressBar x:Name="CpuTempBar" Grid.Column="1" Height="8" VerticalAlignment="Center"
                               Margin="8,0,8,0" Minimum="0" Maximum="100"/>
                  <TextBlock Grid.Column="2" x:Name="CpuTempText" Text="-" FontSize="11"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                             VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>
                <Grid Margin="0,0,0,6">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="64"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="{x:Static app:Strings.UtilizationLabel}" FontSize="11"
                             Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                             VerticalAlignment="Center"/>
                  <ProgressBar x:Name="CpuUtilBar" Grid.Column="1" Height="8" VerticalAlignment="Center"
                               Margin="8,0,8,0" Minimum="0" Maximum="100"/>
                  <TextBlock Grid.Column="2" x:Name="CpuUtilText" Text="-" FontSize="11"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                             VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>
                <Grid Margin="0,0,0,6">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="64"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="{x:Static app:Strings.FanLabel}" FontSize="11"
                             Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                             VerticalAlignment="Center"/>
                  <ProgressBar x:Name="CpuFanBar" Grid.Column="1" Height="8" VerticalAlignment="Center"
                               Margin="8,0,8,0" Minimum="0" Maximum="6400"/>
                  <TextBlock Grid.Column="2" x:Name="CpuFanText" Text="-" FontSize="11"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                             VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="64"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="{x:Static app:Strings.PowerLabel}" FontSize="11"
                             Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                             VerticalAlignment="Center"/>
                  <ProgressBar x:Name="CpuPowerBar" Grid.Column="1" Height="8" VerticalAlignment="Center"
                               Margin="8,0,8,0" Minimum="0" Maximum="150"/>
                  <TextBlock Grid.Column="2" x:Name="CpuPowerText" Text="-" FontSize="11"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                             VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>
              </StackPanel>
              <TextBlock x:Name="CpuOffMessage" Grid.Row="1" Text="{x:Static app:Strings.CpuMonitorOff}"
                         FontSize="12" FontStyle="Italic"
                         Foreground="{DynamicResource TextFillColorDisabledBrush}"
                         VerticalAlignment="Center" HorizontalAlignment="Center"
                         Visibility="Collapsed"/>
            </Grid>
          </ui:CardControl.Header>
        </ui:CardControl>

        <!-- GPU -->
        <ui:CardControl Grid.Row="0" Grid.Column="2">
          <ui:CardControl.Header>
            <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                  <ui:SymbolIcon Symbol="DeviceEq24" FontSize="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
                  <TextBlock Text="{x:Static app:Strings.MonitorGpuLabel}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
                <Path x:Name="GpuBrandLogo" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Top"
                      Width="40" Height="40" Margin="0,4,4,0" Opacity="0.06" Stretch="Uniform"
                      IsHitTestVisible="False" Fill="Transparent" Visibility="Collapsed"/>
              </Grid>
              <Border Grid.Row="1" Height="1" Background="{DynamicResource DividerStrokeDefaultBrush}" Margin="0,8,0,6" Opacity="0.3"/>
              <StackPanel x:Name="GpuDetailPanel" Grid.Row="1" Margin="0,8,0,0">
                <Grid Margin="0,0,0,6">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="64"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="{x:Static app:Strings.TempCelsius}" FontSize="11"
                             Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                             VerticalAlignment="Center"/>
                  <ProgressBar x:Name="GpuTempBar" Grid.Column="1" Height="8" VerticalAlignment="Center"
                               Margin="8,0,8,0" Minimum="0" Maximum="100"/>
                  <TextBlock Grid.Column="2" x:Name="GpuTempText" Text="-" FontSize="11"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                             VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>
                <Grid Margin="0,0,0,6">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="64"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="{x:Static app:Strings.UtilizationLabel}" FontSize="11"
                             Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                             VerticalAlignment="Center"/>
                  <ProgressBar x:Name="GpuUtilBar" Grid.Column="1" Height="8" VerticalAlignment="Center"
                               Margin="8,0,8,0" Minimum="0" Maximum="100"/>
                  <TextBlock Grid.Column="2" x:Name="GpuUtilText" Text="-" FontSize="11"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                             VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>
                <Grid Margin="0,0,0,6">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="64"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="{x:Static app:Strings.FanLabel}" FontSize="11"
                             Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                             VerticalAlignment="Center"/>
                  <ProgressBar x:Name="GpuFanBar" Grid.Column="1" Height="8" VerticalAlignment="Center"
                               Margin="8,0,8,0" Minimum="0" Maximum="6400"/>
                  <TextBlock Grid.Column="2" x:Name="GpuFanText" Text="-" FontSize="11"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                             VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="64"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="{x:Static app:Strings.PowerLabel}" FontSize="11"
                             Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                             VerticalAlignment="Center"/>
                  <ProgressBar x:Name="GpuPowerBar" Grid.Column="1" Height="8" VerticalAlignment="Center"
                               Margin="8,0,8,0" Minimum="0" Maximum="300"/>
                  <TextBlock Grid.Column="2" x:Name="GpuPowerText" Text="-" FontSize="11"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                             VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>
              </StackPanel>
              <TextBlock x:Name="GpuOffMessage" Grid.Row="1" Text="{x:Static app:Strings.GpuMonitorOff}"
                         FontSize="12" FontStyle="Italic"
                         Foreground="{DynamicResource TextFillColorDisabledBrush}"
                         VerticalAlignment="Center" HorizontalAlignment="Center"
                         Visibility="Collapsed"/>
            </Grid>
          </ui:CardControl.Header>
        </ui:CardControl>

        <!-- Memory -->
        <ui:CardControl Grid.Row="1" Grid.Column="0" Margin="0,12,0,0">
          <ui:CardControl.Header>
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                  <ui:SymbolIcon Symbol="Ram20" FontSize="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
                  <TextBlock Text="{x:Static app:Strings.DashboardMemoryLabel}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
              </Grid>
              <Border Grid.Row="1" Height="1" Background="{DynamicResource DividerStrokeDefaultBrush}" Margin="0,8,0,6" Opacity="0.3"/>
              <StackPanel Grid.Row="1" Margin="0,8,0,0">
                <Grid Margin="0,0,0,6">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="64"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="{x:Static app:Strings.UtilizationLabel}" FontSize="11"
                             Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                             VerticalAlignment="Center"/>
                  <ProgressBar x:Name="RamUsageBar" Grid.Column="1" Height="8" VerticalAlignment="Center"
                               Margin="8,0,8,0" Minimum="0" Maximum="100"/>
                  <TextBlock Grid.Column="2" x:Name="RamUsageText" Text="-" FontSize="11"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                             VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>
                <Grid Margin="0,0,0,4">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="{x:Static app:Strings.DashboardMemoryUsedLabel}" FontSize="11"
                             Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                             VerticalAlignment="Center"/>
                  <TextBlock Grid.Column="1" x:Name="RamDetailText" Text="-" FontSize="11"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                             VerticalAlignment="Center" Margin="8,0,0,0"/>
                </Grid>
                <Grid Margin="0,0,0,4">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="虚拟" FontSize="11"
                             Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                             VerticalAlignment="Center"/>
                  <TextBlock Grid.Column="1" x:Name="RamVirtualText" Text="-" FontSize="11"
                             Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                             VerticalAlignment="Center" Margin="8,0,0,0"/>
                </Grid>
                <Button x:Name="CleanMemBtn" MinHeight="26" Padding="10,2" FontSize="11"
                        HorizontalAlignment="Right" Margin="0,4,0,0"
                        Click="CleanMemory_Click">
                  <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Broom24" FontSize="13" Margin="0,0,4,0"/>
                    <TextBlock Text="{x:Static app:Strings.DashboardMemoryCleanBtn}" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
              </StackPanel>
            </Grid>
          </ui:CardControl.Header>
        </ui:CardControl>

        <!-- Storage -->
        <ui:CardControl Grid.Row="1" Grid.Column="2" Margin="0,12,0,0">
          <ui:CardControl.Header>
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                  <ui:SymbolIcon Symbol="Storage24" FontSize="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
                  <TextBlock Text="{x:Static app:Strings.DashboardStorageLabel}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
              </Grid>
              <Border Grid.Row="1" Height="1" Background="{DynamicResource DividerStrokeDefaultBrush}" Margin="0,8,0,6" Opacity="0.3"/>
              <ScrollViewer Grid.Row="1" MaxHeight="160" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="StoragePanel" Margin="0,8,0,0"/>
              </ScrollViewer>
            </Grid>
          </ui:CardControl.Header>
        </ui:CardControl>
      </Grid>

      <!-- ══════ 系统状态 / 性能预设 (双列) ══════ -->
      <Grid x:Name="StatusGrid" Margin="0,0,0,12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="12"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:CardControl Grid.Row="0" Grid.Column="0">
          <ui:CardControl.Header>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <ui:SymbolIcon Symbol="Info24" FontSize="16" VerticalAlignment="Top" Margin="0,2,0,0"/>
              <StackPanel Grid.Column="1" Margin="10,0,0,0">
                <TextBlock Text="{x:Static app:Strings.SysStatusHeading}" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,10"/>
                <Grid Margin="{StaticResource CardMargin}">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="{x:Static app:Strings.PerfModeLabel}" FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                             VerticalAlignment="Center"/>
                  <TextBlock x:Name="CurrentModeText" Grid.Column="1" Foreground="{DynamicResource AccentOmenBrush}"
                             FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                </Grid>
                <Grid Margin="{StaticResource CardMargin}">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="{x:Static app:Strings.FanControl}" FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                             VerticalAlignment="Center"/>
                  <TextBlock x:Name="CurrentFanText" Grid.Column="1" Foreground="{DynamicResource AccentOmenBrush}"
                             FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                </Grid>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="{x:Static app:Strings.PowerStatus}" FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                             VerticalAlignment="Center"/>
                  <TextBlock x:Name="PowerStatusText" Grid.Column="1" Foreground="{DynamicResource AccentGreenBrush}"
                             FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                </Grid>
              </StackPanel>
            </Grid>
          </ui:CardControl.Header>
        </ui:CardControl>

        <ui:CardControl Grid.Row="0" Grid.Column="2">
          <ui:CardControl.Header>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <ui:SymbolIcon Symbol="PresenceAvailable24" FontSize="16" VerticalAlignment="Top" Margin="0,2,0,0"/>
              <StackPanel Grid.Column="1" Margin="10,0,0,0">
                <TextBlock Text="{x:Static app:Strings.SysPresetsHeading}" FontWeight="SemiBold"
                           FontSize="13" Margin="0,0,0,10"/>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <ComboBox x:Name="PresetCombo" MinWidth="120"
                            SelectionChanged="Preset_SelectionChanged"/>
                  <Button x:Name="PresetRenameBtn" Grid.Column="1" Width="28" Height="28"
                          Padding="0" Margin="4,0" Click="PresetRename_Click"
                          ToolTip="{x:Static app:Strings.RenamePreset}" Visibility="Collapsed">
                    <ui:SymbolIcon Symbol="Edit24" FontSize="13"/>
                  </Button>
                  <Button x:Name="PresetSaveBtn" Grid.Column="2" Width="28" Height="28"
                          Padding="0" Margin="4,0" Click="PresetSave_Click"
                          ToolTip="{x:Static app:Strings.SaveTooltip}" Visibility="Collapsed">
                    <ui:SymbolIcon Symbol="Checkmark24" FontSize="13"/>
                  </Button>
                </Grid>
              </StackPanel>
            </Grid>
          </ui:CardControl.Header>
        </ui:CardControl>

      </Grid>

      <!-- ══════ 系统信息 / Device Info (migrated from SysInfoPage) ══════ -->
      <Border Height="1" Background="{DynamicResource DividerStrokeDefaultBrush}" Margin="0,8,0,16" Opacity="0.3"/>

      <Grid x:Name="SysInfoGrid">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,4,0">
          <ui:CardControl Margin="0,0,0,8">
          <ui:CardControl.Header>
            <StackPanel>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <ui:SymbolIcon Symbol="Info24" FontSize="18" Margin="0,0,8,0"/>
                <TextBlock Text="{x:Static app:Strings.SysInfoHeading}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource AccentOmenBrush}" VerticalAlignment="Center"/>
              </StackPanel>
              <TextBlock x:Name="SysManufacturerText" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/>
              <TextBlock x:Name="SysModelText" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/>
              <TextBlock x:Name="SysProductNameText" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/>
              <TextBlock x:Name="SysValidationText" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/>
              <TextBlock x:Name="SysBoardText" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/>
              <TextBlock x:Name="SysBiosText" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/>
              <TextBlock x:Name="SysCpuText" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/>
              <TextBlock x:Name="SysCpuTjmaxText" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/>
              <TextBlock x:Name="SysGpuText" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/>
              <TextBlock x:Name="SysNvidiaTjmaxText" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/>
              <TextBlock x:Name="SysNvidiaPowerText" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/>
              <TextBlock x:Name="SysAdapterText" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/>
              <TextBlock x:Name="SysKbLightTypeText" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/>
            </StackPanel>
          </ui:CardControl.Header>
        </ui:CardControl>

          <ui:CardControl>
            <ui:CardControl.Header>
              <StackPanel>
                <Grid Margin="0,0,0,10">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Info24" FontSize="18" Margin="0,0,8,0"/>
                    <TextBlock Text="{x:Static app:Strings.SensorTempsHeading}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource AccentOmenBrush}"/>
                  </StackPanel>
                  <Button x:Name="SysInfoRefreshBtn" Grid.Column="1"
                          Width="26" Height="20" Padding="0" Click="SysInfoRefresh_Click">
                    <ui:SymbolIcon Symbol="ArrowReset24" FontSize="14"/>
                  </Button>
                </Grid>
                <TextBlock x:Name="SysCpuTempText" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                <TextBlock x:Name="SysGpuTempText" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                <TextBlock x:Name="SysIrSensorText" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                <TextBlock x:Name="SysAmbientText" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                <TextBlock x:Name="SysPchText" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                <TextBlock x:Name="SysVrText" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
              </StackPanel>
            </ui:CardControl.Header>
          </ui:CardControl>
        </StackPanel>

        <StackPanel Grid.Row="0" Grid.Column="1" Margin="4,0,0,0">
          <ui:CardControl Margin="0,0,0,8">
            <ui:CardControl.Header>
              <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                  <ui:SymbolIcon Symbol="Settings24" FontSize="18" Margin="0,0,8,0"/>
                  <TextBlock Text="{x:Static app:Strings.SysPawnTitle}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource AccentOmenBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="SysPawnIoText" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/>
              </StackPanel>
            </ui:CardControl.Header>
          </ui:CardControl>

          <ui:CardControl Margin="0,0,0,8">
            <ui:CardControl.Header>
              <StackPanel>
                <Grid Margin="0,0,0,10">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Info24" FontSize="18" Margin="0,0,8,0"/>
                    <TextBlock Text="HP 驱动下载 / HP Driver Download" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource AccentOmenBrush}" VerticalAlignment="Center"/>
                  </StackPanel>
                  <Button Grid.Column="1" Width="26" Height="20" Padding="0" Click="HpDriverSearch_Click">
                    <ui:SymbolIcon Symbol="ArrowRight24" FontSize="14"/>
                  </Button>
                </Grid>
                <TextBlock x:Name="SysDriverModelText" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" TextWrapping="Wrap" Margin="0,4,0,0"
                           Text="点击右侧按钮打开 HP 官方驱动页面"/>
              </StackPanel>
            </ui:CardControl.Header>
          </ui:CardControl>

          <ui:CardControl>
            <ui:CardControl.Header>
              <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                  <ui:SymbolIcon Symbol="LeafOne24" FontSize="18" Margin="0,0,8,0"/>
                  <TextBlock Text="{x:Static app:Strings.HwMonitorHeading}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource AccentOmenBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                  <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{x:Static app:Strings.MonitorCpuLabel}" FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" VerticalAlignment="Center"/>
                    <ComboBox x:Name="MonCpuCombo" Grid.Column="1" MinWidth="100"
                              SelectionChanged="MonCpu_SelectionChanged">
                      <ComboBoxItem Content="{x:Static app:Strings.MonitorCpuOn}"/>
                      <ComboBoxItem Content="{x:Static app:Strings.MonitorCpuOff}"/>
                    </ComboBox>
                  </Grid>
                  <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{x:Static app:Strings.MonitorGpuLabel}" FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" VerticalAlignment="Center"/>
                    <ComboBox x:Name="MonGpuCombo" Grid.Column="1" MinWidth="100"
                              SelectionChanged="MonGpu_SelectionChanged">
                      <ComboBoxItem Content="{x:Static app:Strings.MonitorGpuOn}"/>
                      <ComboBoxItem Content="{x:Static app:Strings.MonitorGpuOff}"/>
                    </ComboBox>
                  </Grid>
                  <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{x:Static app:Strings.FanLabel}" FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" VerticalAlignment="Center"/>
                    <ComboBox x:Name="MonFanCombo" Grid.Column="1" MinWidth="100"
                              SelectionChanged="MonFan_SelectionChanged">
                      <ComboBoxItem Content="{x:Static app:Strings.MonitorFanOn}"/>
                      <ComboBoxItem Content="{x:Static app:Strings.MonitorFanOff}"/>
                    </ComboBox>
                  </Grid>
                  <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{x:Static app:Strings.DashboardMemoryLabel}" FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" VerticalAlignment="Center"/>
                    <ComboBox x:Name="MonMemoryCombo" Grid.Column="1" MinWidth="100"
                              SelectionChanged="MonMemory_SelectionChanged">
                      <ComboBoxItem Content="{x:Static app:Strings.MonitorMemoryOn}"/>
                      <ComboBoxItem Content="{x:Static app:Strings.MonitorMemoryOff}"/>
                    </ComboBox>
                  </Grid>
                  <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="网速" FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" VerticalAlignment="Center"/>
                    <ComboBox x:Name="MonNetworkCombo" Grid.Column="1" MinWidth="100"
                              SelectionChanged="MonNetwork_SelectionChanged">
                      <ComboBoxItem Content="{x:Static app:Strings.MonitorNetworkOn}"/>
                      <ComboBoxItem Content="{x:Static app:Strings.MonitorNetworkOff}"/>
                    </ComboBox>
                  </Grid>
                  <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="FPS" FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" VerticalAlignment="Center"/>
                    <ComboBox x:Name="MonFpsCombo" Grid.Column="1" MinWidth="100"
                              SelectionChanged="MonFps_SelectionChanged">
                      <ComboBoxItem Content="{x:Static app:Strings.MonitorFpsOn}"/>
                      <ComboBoxItem Content="{x:Static app:Strings.MonitorFpsOff}"/>
                    </ComboBox>
                  </Grid>
                  <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{x:Static app:Strings.MonitorRefresh}" FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" VerticalAlignment="Center"/>
                    <ComboBox x:Name="MonRefreshCombo" Grid.Column="1" MinWidth="100"
                              SelectionChanged="MonRefresh_SelectionChanged">
                      <ComboBoxItem Content="{x:Static app:Strings.MonitorRefreshHigh}"/>
                      <ComboBoxItem Content="{x:Static app:Strings.MonitorRefreshLow}"/>
                    </ComboBox>
                  </Grid>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{x:Static app:Strings.TempDisplayMode}" FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" VerticalAlignment="Center"/>
                    <ComboBox x:Name="TempDispCombo" Grid.Column="1" MinWidth="100"
                              SelectionChanged="TempDisplay_SelectionChanged">
                      <ComboBoxItem Content="{x:Static app:Strings.TempSmoothedShort}"/>
                      <ComboBoxItem Content="{x:Static app:Strings.TempRawShort}"/>
                    </ComboBox>
                  </Grid>
              </StackPanel>
            </ui:CardControl.Header>
          </ui:CardControl>
        </StackPanel>
      </Grid>

      <ui:CardControl Margin="0,8,0,0">
        <ui:CardControl.Header>
          <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
              <ui:SymbolIcon Symbol="DeviceEq24" FontSize="18" Margin="0,0,8,0"/>
              <TextBlock Text="{x:Static app:Strings.GpuAppsMenu}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource AccentOmenBrush}" VerticalAlignment="Center"/>
            </StackPanel>
            <ListBox x:Name="GpuAppList"
                     Height="120" Margin="{StaticResource CardMargin}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     PreviewMouseWheel="GpuAppList_PreviewMouseWheel"
                     PreviewMouseRightButtonDown="GpuAppList_PreviewMouseRightButtonDown">
              <ListBox.ContextMenu>
                <ContextMenu>
                  <MenuItem x:Name="GpuAppLocateMenu" Header="{x:Static app:Strings.GpuAppLocate}"
                             Click="GpuAppLocate_Click"/>
                  <MenuItem x:Name="GpuAppEndTaskMenu" Header="{x:Static app:Strings.GpuAppEndTask}"
                             Click="GpuAppEndTask_Click"/>
                  <MenuItem x:Name="GpuPrefHeading" Header="{x:Static app:Strings.GpuPrefHeading}" >
                    <MenuItem x:Name="GpuPrefAuto" Header="{x:Static app:Strings.GpuPrefAuto}" 
                              Click="GpuAppPrefAuto_Click"/>
                    <MenuItem x:Name="GpuPrefPowerSave" Header="{x:Static app:Strings.GpuPrefPowerSave}" 
                              Click="GpuAppPrefPowerSave_Click"/>
                    <MenuItem x:Name="GpuPrefHighPerf" Header="{x:Static app:Strings.GpuPrefHighPerf}" 
                              Click="GpuAppPrefHighPerf_Click"/>
                  </MenuItem>
                </ContextMenu>
              </ListBox.ContextMenu>
            </ListBox>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <WrapPanel Grid.Column="1">
                <Button Content="{x:Static app:Strings.ButtonRefresh}"
                        MinWidth="80" Click="RefreshGpuApps_Click"/>
                <Button Content="{x:Static app:Strings.GpuRestartMenu}"
                        MinWidth="100" Margin="8,0,0,0" Click="RestartGpu_Click"/>
              </WrapPanel>
            </Grid>
          </StackPanel>
        </ui:CardControl.Header>
      </ui:CardControl>

    </StackPanel>
  </ScrollViewer>
</Page>
