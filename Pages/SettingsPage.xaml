<Page x:Class="OmenSuperHub.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:app="clr-namespace:OmenSuperHub"
      Title="{x:Static app:Strings.PageSettings}">
<ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="24,20" TextElement.Foreground="{DynamicResource TextPrimaryBrush}">
      <TextBlock x:Name="HeadingSettings" Text="{x:Static app:Strings.PageSettings}" FontSize="22" FontWeight="Bold" Margin="0,0,0,20"/>

      <!-- ══════ 浮窗设置 ══════ -->
      <TextBlock Text="{x:Static app:Strings.SettingsFloatingHeading}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>

      <!-- 浮窗显示 -->
      <ui:CardControl Margin="0,0,0,8">
        <ui:CardControl.Header>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
              <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Window24" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{x:Static app:Strings.FloatingHeading}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
              </StackPanel>
            </StackPanel>
            <ui:ToggleSwitch x:Name="FloatingToggle" Grid.Column="1" VerticalAlignment="Center"
                            Checked="FloatingToggle_Changed" Unchecked="FloatingToggle_Changed"/>
          </Grid>
        </ui:CardControl.Header>
      </ui:CardControl>

      <!-- 显示器选择 -->
      <ui:CardControl Margin="0,0,0,8">
        <ui:CardControl.Header>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock Text="{x:Static app:Strings.DisplayHeading}" FontSize="13" FontWeight="SemiBold"/>
            </StackPanel>
            <WrapPanel x:Name="FloatScreenPanel" Grid.Column="1"/>
          </Grid>
        </ui:CardControl.Header>
      </ui:CardControl>

      <!-- 浮窗位置 -->
      <ui:CardControl Margin="0,0,0,8">
        <ui:CardControl.Header>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock Text="{x:Static app:Strings.PositionHeading}" FontSize="13" FontWeight="SemiBold"/>
            </StackPanel>
            <ComboBox x:Name="FloatLocCombo" Grid.Column="1" MinWidth="140"
                      SelectionChanged="FloatLoc_SelectionChanged">
              <ComboBoxItem Content="{x:Static app:Strings.FloatingLocLeft}"/>
              <ComboBoxItem Content="{x:Static app:Strings.FloatingLocRight}"/>
              <ComboBoxItem Content="{x:Static app:Strings.FloatingLocTopCenter}"/>
              <ComboBoxItem Content="{x:Static app:Strings.FloatingLocFree}"/>
            </ComboBox>
          </Grid>
        </ui:CardControl.Header>
      </ui:CardControl>

      <!-- 浮窗布局 -->
      <ui:CardControl Margin="0,0,0,8">
        <ui:CardControl.Header>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock Text="{x:Static app:Strings.FloatLayoutHeading}" FontSize="13" FontWeight="SemiBold"/>
            </StackPanel>
            <ComboBox x:Name="FloatLayoutCombo" Grid.Column="1" MinWidth="120"
                      SelectionChanged="FloatLayout_SelectionChanged">
              <ComboBoxItem Content="{x:Static app:Strings.FloatLayoutRow}"/>
              <ComboBoxItem Content="{x:Static app:Strings.FloatLayoutCol}"/>
            </ComboBox>
          </Grid>
        </ui:CardControl.Header>
      </ui:CardControl>

      <!-- 文字大小 -->
      <ui:CardControl Margin="0,0,0,8">
        <ui:CardControl.Header>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock Text="{x:Static app:Strings.FontSizeHeading}" FontSize="13" FontWeight="SemiBold"/>
            </StackPanel>
            <Grid Grid.Column="1" VerticalAlignment="Center" Width="160">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <Slider x:Name="FloatSizeSlider" Minimum="14" Maximum="72" Value="36"
                      SmallChange="1" LargeChange="4" TickFrequency="2"
                      ValueChanged="FloatSize_Changed"/>
              <TextBlock x:Name="FloatSizeVal" Grid.Column="1" Text="36"
                         FontSize="12" Width="40" TextAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
          </Grid>
        </ui:CardControl.Header>
      </ui:CardControl>

      <!-- 文字透明度 -->
      <ui:CardControl Margin="0,0,0,8">
        <ui:CardControl.Header>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock Text="{x:Static app:Strings.TextOpacityHeading}" FontSize="13" FontWeight="SemiBold"/>
            </StackPanel>
            <Grid Grid.Column="1" VerticalAlignment="Center" Width="160">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <Slider x:Name="FloatTextOpacitySlider" Minimum="0.1" Maximum="1.0" Value="1.0"
                      SmallChange="0.05" LargeChange="0.1" TickFrequency="0.1"
                      ValueChanged="FloatTextOpacity_Changed"/>
              <TextBlock x:Name="FloatTextOpacityVal" Grid.Column="1" Text="100%"
                         FontSize="12" Width="40" TextAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
          </Grid>
        </ui:CardControl.Header>
      </ui:CardControl>

      <!-- ══════ 硬件设置 ══════ -->
      <TextBlock Text="{x:Static app:Strings.SettingsHardwareHeading}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,8,0,8"/>

      <!-- OMEN 键 — 有子选项的组合卡片 -->
      <ui:CardControl Margin="0,0,0,8">
        <ui:CardControl.Header>
          <StackPanel>
            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Keyboard24" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{x:Static app:Strings.OmenKeyHeading}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
              </StackPanel>
              <ComboBox x:Name="OmenKeyCombo" Grid.Column="1" MinWidth="160"
                        SelectionChanged="OmenKey_SelectionChanged">
                <ComboBoxItem Content="{x:Static app:Strings.OmenKeyCustomLabel}"/>
                <ComboBoxItem Content="{x:Static app:Strings.OmenKeyShowMain}"/>
                <ComboBoxItem Content="{x:Static app:Strings.OmenKeyCycle}"/>
                <ComboBoxItem Content="{x:Static app:Strings.OmenKeyLaunchApp}"/>
                <ComboBoxItem Content="{x:Static app:Strings.OmenKeyNone}"/>
              </ComboBox>
            </Grid>
            <!-- 附属：应用选择 -->
            <Grid x:Name="OmenKeyAppPanel" Visibility="Collapsed" Margin="0,0,0,6">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBlock x:Name="OmenKeyAppPathText" FontSize="12"
                         VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                         Tag="OmenKeyNoAppSelected"/>
              <ui:Button x:Name="OmenKeySelectAppBtn" Grid.Column="1"
                      Width="32" Height="32" Padding="0" Background="Transparent"
                      Appearance="Transparent"
                      Click="OmenKeySelectApp_Click">
                <ui:SymbolIcon Symbol="ChevronRight24" FontSize="14"/>
              </ui:Button>
            </Grid>
            <!-- 附属：循环候选 -->
            <StackPanel x:Name="OmenKeyCyclePanel" Visibility="Collapsed" Margin="0,6,0,0">
              <TextBlock Text="{x:Static app:Strings.OmenKeyPresetCandidates}" FontSize="12"
                         Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
              <WrapPanel>
                <CheckBox x:Name="CycleExtreme" Content="{x:Static app:Strings.PresetExtreme}"
                          Checked="CycleCandidate_Changed" Unchecked="CycleCandidate_Changed"/>
                <CheckBox x:Name="CycleGpuPriority" Content="{x:Static app:Strings.PresetGpuPriority}"
                          Checked="CycleCandidate_Changed" Unchecked="CycleCandidate_Changed"/>
                <CheckBox x:Name="CycleLightUse" Content="{x:Static app:Strings.PresetLightUse}"
                          Checked="CycleCandidate_Changed" Unchecked="CycleCandidate_Changed"/>
              </WrapPanel>
              <!-- ponytail: custom preset candidates built dynamically from Presets/*.json -->
              <WrapPanel x:Name="CycleCustomsHost" Margin="0,4,0,0"/>
            </StackPanel>
          </StackPanel>
        </ui:CardControl.Header>
      </ui:CardControl>

      <!-- ══════ 界面设置 ══════ -->
      <TextBlock Text="{x:Static app:Strings.SettingsUiHeading}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,8,0,8"/>

      <!-- OSD 开关 -->
      <ui:CardControl Margin="0,0,0,8">
        <ui:CardControl.Header>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
              <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Chat24" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="OSD" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
              </StackPanel>
              <TextBlock Text="{x:Static app:Strings.OsdToggleDesc}" FontSize="11"
                         Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
            </StackPanel>
            <ui:ToggleSwitch x:Name="OsdToggle" Grid.Column="1" VerticalAlignment="Center"
                            Checked="OsdToggle_Changed" Unchecked="OsdToggle_Changed"/>
          </Grid>
        </ui:CardControl.Header>
      </ui:CardControl>



      <!-- 托盘图标 -->
      <ui:CardControl Margin="0,0,0,8">
        <ui:CardControl.Header>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
              <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Window24" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{x:Static app:Strings.TrayIconHeading}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
              </StackPanel>
            </StackPanel>
            <ComboBox x:Name="TrayIconCombo" Grid.Column="1" MinWidth="140"
                      SelectionChanged="TrayIcon_SelectionChanged">
              <ComboBoxItem Content="{x:Static app:Strings.IconOriginal}"/>
              <ComboBoxItem Content="{x:Static app:Strings.IconCustom}"/>
              <ComboBoxItem Content="{x:Static app:Strings.IconDynamic}"/>
            </ComboBox>
          </Grid>
        </ui:CardControl.Header>
      </ui:CardControl>

      <!-- 自动启动 -->
      <ui:CardControl Margin="0,0,0,8">
        <ui:CardControl.Header>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock Text="{x:Static app:Strings.AutoStartHeading}" FontSize="13" FontWeight="SemiBold"/>
              <TextBlock Text="{x:Static app:Strings.AutoStartDesc}" FontSize="11"
                         Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
            </StackPanel>
            <ui:ToggleSwitch x:Name="AutoStartToggle" Grid.Column="1" VerticalAlignment="Center"
                            Checked="AutoStartToggle_Changed" Unchecked="AutoStartToggle_Changed"/>
          </Grid>
        </ui:CardControl.Header>
      </ui:CardControl>

      <!-- 自定义 Logo — > 按钮跳转 -->
      <ui:CardControl Margin="0,0,0,8">
        <ui:CardControl.Header>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
              <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Image24" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock x:Name="CustomLogoHeadingText" Text="{x:Static app:Strings.CustomLogoHeading}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
              </StackPanel>
              <TextBlock x:Name="CustomLogoDescText" Text="{x:Static app:Strings.CustomLogoDesc}" FontSize="11"
                         Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
              <ui:Button x:Name="CustomLogoSelectBtn" Width="32" Height="32" Padding="0" Background="Transparent"
                      Appearance="Transparent"
                      Click="CustomLogoSelect_Click">
                <ui:SymbolIcon Symbol="ChevronRight24" FontSize="14"/>
              </ui:Button>
              <ui:Button x:Name="CustomLogoResetBtn" Width="32" Height="32" Padding="0" Background="Transparent"
                      Margin="4,0,0,0" Appearance="Transparent"
                      Click="CustomLogoReset_Click">
                <ui:SymbolIcon Symbol="ArrowReset24" FontSize="14"/>
              </ui:Button>
            </StackPanel>
          </Grid>
        </ui:CardControl.Header>
      </ui:CardControl>

      <!-- ══════ 系统设置 ══════ -->
      <TextBlock Text="{x:Static app:Strings.SettingsSysHeading}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,8,0,8"/>

      <!-- 主题 -->
      <ui:CardControl Margin="0,0,0,8">
        <ui:CardControl.Header>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
              <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="DarkTheme24" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{x:Static app:Strings.ThemeHeading}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
              </StackPanel>
            </StackPanel>
            <ComboBox x:Name="ThemeCombo" Grid.Column="1" MinWidth="140"
                      SelectionChanged="Theme_SelectionChanged">
              <ComboBoxItem Content="{x:Static app:Strings.ThemeSystem}"/>
              <ComboBoxItem Content="{x:Static app:Strings.ThemeDark}"/>
              <ComboBoxItem Content="{x:Static app:Strings.ThemeLight}"/>
            </ComboBox>
          </Grid>
        </ui:CardControl.Header>
      </ui:CardControl>

      <!-- 语言 -->
      <ui:CardControl Margin="0,0,0,8">
        <ui:CardControl.Header>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
              <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Globe24" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{x:Static app:Strings.LanguageMenu}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
              </StackPanel>
            </StackPanel>
            <ComboBox x:Name="LangCombo" Grid.Column="1" MinWidth="160"
                      SelectionChanged="Lang_SelectionChanged">
              <ComboBoxItem Content="{x:Static app:Strings.LangSimplified}"/>
              <ComboBoxItem Content="{x:Static app:Strings.LangTraditional}"/>
              <ComboBoxItem Content="{x:Static app:Strings.LangEnglish}"/>
            </ComboBox>
          </Grid>
        </ui:CardControl.Header>
      </ui:CardControl>

      <!-- 自定义背景 — 有子选项的组合卡片 -->
      <ui:CardControl Margin="0,0,0,8">
        <ui:CardControl.Header>
          <StackPanel>
            <Grid Margin="0,0,0,6">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Image24" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{x:Static app:Strings.CustomBgHeading}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
              </StackPanel>
              <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <ui:Button x:Name="CustomBgSelectBtn" Width="32" Height="32" Padding="0" Background="Transparent"
                        Appearance="Transparent"
                        Click="CustomBgSelect_Click">
                  <ui:SymbolIcon Symbol="ChevronRight24" FontSize="14"/>
                </ui:Button>
                <ui:Button x:Name="CustomBgResetBtn" Width="32" Height="32" Padding="0" Background="Transparent"
                        Margin="4,0,0,0" Appearance="Transparent"
                        Click="CustomBgReset_Click">
                  <ui:SymbolIcon Symbol="ArrowReset24" FontSize="14"/>
                </ui:Button>
              </StackPanel>
            </Grid>
            <TextBlock x:Name="CustomBgPathText" Text="{x:Static app:Strings.CustomBgDesc}" FontSize="11"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis"
                       Margin="0,0,0,6"/>
            <Grid Margin="0,0,0,4">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBlock Text="{x:Static app:Strings.CustomBgOpacity}" FontSize="12" VerticalAlignment="Center"/>
              <Grid Grid.Column="1" VerticalAlignment="Center" Width="160">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Slider x:Name="CustomBgOpacitySlider" Minimum="0.0" Maximum="1.0" Value="0.5"
                        SmallChange="0.05" LargeChange="0.1" TickFrequency="0.1"
                        ValueChanged="CustomBgOpacity_Changed"/>
                <TextBlock x:Name="CustomBgOpacityVal" Grid.Column="1" Text="50%"
                           FontSize="12" Width="40" TextAlignment="Right" VerticalAlignment="Center"/>
              </Grid>
            </Grid>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBlock Text="{x:Static app:Strings.CustomBgBlur}" FontSize="12" VerticalAlignment="Center"/>
              <ui:ToggleSwitch x:Name="CustomBgBlurToggle" Grid.Column="1"
                              Checked="CustomBgBlur_Changed" Unchecked="CustomBgBlur_Changed"/>
            </Grid>
          </StackPanel>
        </ui:CardControl.Header>
      </ui:CardControl>

      <!-- 数据本地化 -->
      <ui:CardControl Margin="0,0,0,8">
        <ui:CardControl.Header>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock Text="{x:Static app:Strings.DataLocalizeHeading}" FontSize="13" FontWeight="SemiBold"/>
              <TextBlock Text="{x:Static app:Strings.DataLocalizeDesc}" FontSize="11"
                         Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
            </StackPanel>
            <ui:ToggleSwitch x:Name="DataLocalizeToggle" Grid.Column="1" VerticalAlignment="Center"
                            Checked="DataLocalizeToggle_Changed" Unchecked="DataLocalizeToggle_Changed"/>
          </Grid>
        </ui:CardControl.Header>
      </ui:CardControl>

      <!-- 调试日志 + 显示所有 UI (DEBUG模式) -->
      <ui:CardControl Margin="0,0,0,8">
        <ui:CardControl.Header>
          <StackPanel>
            <!-- 调试日志开关 -->
            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="{x:Static app:Strings.DebugLogHeading}" FontSize="13" FontWeight="SemiBold"/>
                <TextBlock x:Name="DebugLogDesc" Text="{x:Static app:Strings.DebugLogDesc}" FontSize="11"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
              </StackPanel>
              <ui:ToggleSwitch x:Name="DebugLogToggle" Grid.Column="1" VerticalAlignment="Center"
                              Checked="DebugLogToggle_Changed" Unchecked="DebugLogToggle_Changed"/>
            </Grid>
            <!-- 显示所有 UI (DEBUG) -->
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="DEBUG: 显示所有UI" FontSize="13" FontWeight="SemiBold"/>
                <TextBlock Text="强制展示所有隐藏的功能卡片，即使硬件不支持。仅用于开发调试。" FontSize="11"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
              </StackPanel>
              <ui:ToggleSwitch x:Name="DebugShowAllUiToggle" Grid.Column="1" VerticalAlignment="Center"
                              Checked="DebugShowAllUiToggle_Changed" Unchecked="DebugShowAllUiToggle_Changed"/>
            </Grid>
          </StackPanel>
        </ui:CardControl.Header>
      </ui:CardControl>

    </StackPanel>
  </ScrollViewer>
</Page>
