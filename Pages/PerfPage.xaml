                  <ui:NumberBox x:Name="CoreKeepGuardInterval" Grid.Column="2" MinWidth="60" Height="34" Minimum="1" Maximum="10" 
                               Value="2" SpinButtonPlacementMode="Inline" Margin="0,0,8,0"
                               ValueChanged="CoreKeepGuardInterval_Changed"/>
                  <ui:Button x:Name="CoreKeepBenchBtn" Grid.Column="4" MinWidth="70"
                          Content="{x:Static app:Strings.CoreKeepBenchmark}" Margin="0,0,0,0" Appearance="Secondary" Click="CoreKeepBenchmark_Click"/>
                </Grid>
              </StackPanel>
            </Grid>
          </ui:CardControl.Header>
        </ui:CardControl>

      </Grid>

      <StackPanel Orientation="Horizontal" Margin="0,8,0,12">
        <ui:SymbolIcon Symbol="DeviceEq24" FontSize="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
