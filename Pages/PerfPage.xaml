                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="{x:Static app:Strings.CoreKeepProcessLabel}" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
