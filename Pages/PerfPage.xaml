              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="{x:Static app:Strings.ResolutionHeading}" FontWeight="SemiBold"/>
                <TextBlock Text="{x:Static app:Strings.PerfResolutionDesc}" FontSize="12"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,2,0,0"/>
              </StackPanel>
              <ComboBox Grid.Column="1" x:Name="ResolutionCombo" MinWidth="130" VerticalAlignment="Top" Margin="0,0,12,0"
                        SelectionChanged="Resolution_SelectionChanged"/>
            </Grid>
          </ui:CardControl.Header>
        </ui:CardControl>

        <!-- DPI Scale -->
        <ui:CardControl Grid.Row="5" Grid.Column="1" Margin="4,0,0,8">
          <ui:CardControl.Header>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="{x:Static app:Strings.DpiScaleHeading}" FontWeight="SemiBold"/>
                <TextBlock Text="{x:Static app:Strings.PerfDpiDesc}" FontSize="12"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,2,0,0"/>
              </StackPanel>
              <ComboBox Grid.Column="1" x:Name="DpiCombo" MinWidth="100" VerticalAlignment="Top" Margin="0,0,12,0"
                        SelectionChanged="DpiCombo_SelectionChanged"/>
            </Grid>
          </ui:CardControl.Header>
        </ui:CardControl>

        <!-- HDR -->
        <ui:CardControl Grid.Row="6" Grid.Column="0" Margin="0,0,4,8" x:Name="HdrCard">
          <ui:CardControl.Header>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="{x:Static app:Strings.HdrHeading}" FontWeight="SemiBold"/>
                <TextBlock Text="{x:Static app:Strings.PerfHdrDesc}" FontSize="12"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,2,0,0"/>
              </StackPanel>
              <ui:ToggleSwitch Grid.Column="1" x:Name="HdrToggle" VerticalAlignment="Center" Margin="0,0,12,0"
                               Click="HdrToggle_Click"/>
            </Grid>
          </ui:CardControl.Header>
        </ui:CardControl>

        <!-- Turn Off Display -->
        <ui:CardControl Grid.Row="6" Grid.Column="1" Margin="4,0,0,8">
          <ui:CardControl.Header>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="{x:Static app:Strings.TurnOffDisplayHeading}" FontWeight="SemiBold"/>
                <TextBlock Text="{x:Static app:Strings.PerfTurnOffDisplayDesc}" FontSize="12"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,2,0,0"/>
              </StackPanel>
              <ui:Button Grid.Column="1" Content="{x:Static app:Strings.TurnOffDisplayBtn}" MinWidth="80"
                         VerticalAlignment="Center" Margin="0,0,12,0"
                         Appearance="Secondary" Click="TurnOffDisplay_Click"/>
            </Grid>
          </ui:CardControl.Header>
        </ui:CardControl>

	      </Grid>


      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
	        <ui:Button x:Name="btnPerfUndo" Height="36" MinWidth="44" Margin="0,0,6,0" ToolTip="{x:Static app:Strings.PerfBtnResetDefaultsTip}" Click="btnPerfUndo_Click" Appearance="Danger">
	          <StackPanel Orientation="Horizontal">
	            <ui:SymbolIcon Symbol="ArrowReset24" FontSize="14" Margin="0,0,4,0"/>
	            <TextBlock VerticalAlignment="Center" Text="{x:Static app:Strings.PerfBtnResetText}"/>
	          </StackPanel>
	        </ui:Button>
	        <ui:Button x:Name="btnPerfLoad" Height="36" MinWidth="44" Margin="0,0,6,0" ToolTip="{x:Static app:Strings.PerfBtnReloadTip}" Click="btnPerfLoad_Click" Appearance="Secondary">
	          <StackPanel Orientation="Horizontal">
	            <ui:SymbolIcon Symbol="ArrowClockwise24" FontSize="14" Margin="0,0,4,0"/>
	            <TextBlock VerticalAlignment="Center" Text="{x:Static app:Strings.PerfBtnReloadText}"/>
	          </StackPanel>
	        </ui:Button>
	        <ui:Button x:Name="btnPerfDelete" Height="36" MinWidth="44" Margin="0,0,6,0" ToolTip="{x:Static app:Strings.PerfBtnDeleteTip}" Click="btnPerfDelete_Click" Appearance="Secondary">
	          <StackPanel Orientation="Horizontal">
	            <ui:SymbolIcon Symbol="Delete24" FontSize="14" Margin="0,0,4,0"/>
	            <TextBlock VerticalAlignment="Center" Text="{x:Static app:Strings.PerfBtnDeleteText}"/>
	          </StackPanel>
	        </ui:Button>
	        <ui:Button x:Name="btnPerfSave" Height="36" MinWidth="44" Margin="0,0,0,0" ToolTip="{x:Static app:Strings.PerfBtnSaveTip}" Click="btnPerfSave_Click" Appearance="Primary">
	          <StackPanel Orientation="Horizontal">
	            <ui:SymbolIcon Symbol="Save24" FontSize="14" Margin="0,0,4,0"/>
	            <TextBlock VerticalAlignment="Center" Text="{x:Static app:Strings.PerfBtnSaveText}"/>
          </StackPanel>
        </ui:Button>
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</Page>
