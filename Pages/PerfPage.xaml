<Page x:Class="OmenSuperHub.Pages.PerfPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:app="clr-namespace:OmenSuperHub"
      xmlns:views="clr-namespace:OmenSuperHub.Views"
      Title="{x:Static app:Strings.PagePerf}"
      SizeChanged="PerfPage_SizeChanged">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="24,20" TextElement.Foreground="{DynamicResource TextPrimaryBrush}">

      <TextBlock Text="{x:Static app:Strings.PerfControl}" FontSize="22" FontWeight="Bold" Margin="0,0,0,16"/>

      <DockPanel Margin="0,0,0,12">
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" HorizontalAlignment="Left">
          <TextBlock FontSize="14" FontWeight="SemiBold" Margin="0,0,8,0" VerticalAlignment="Center">预设:</TextBlock>
          <ComboBox x:Name="cbxPerfPreset" Width="200" Height="36" SelectionChanged="cbxPerfPreset_SelectionChanged"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
          <TextBlock FontSize="14" FontWeight="SemiBold" Margin="0,0,8,0" VerticalAlignment="Center">复制并重命名预设:</TextBlock>
          <ui:TextBox x:Name="tbxPerfPresetName" Width="200" Height="36"/>
        </StackPanel>
      </DockPanel>

      <StackPanel Orientation="Horizontal" Margin="0,8,0,12">
        <ui:SymbolIcon Symbol="DeveloperBoard24" FontSize="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
        <TextBlock Text="{x:Static app:Strings.PerfGroupCpu}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
      </StackPanel>

      <Grid x:Name="CpuPerfGrid">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:CardExpander Grid.Row="0" Grid.Column="0" Margin="0,0,4,8" x:Name="CpuPowerCard"
                         Icon="DeveloperBoard24">
          <ui:CardExpander.Header>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="{x:Static app:Strings.CpuPowerHeading}" FontWeight="SemiBold"/>
                <TextBlock Text="{x:Static app:Strings.PerfAdjustCpuPower}" FontSize="12"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,2,0,0"/>
              </StackPanel>
              <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                <ComboBox x:Name="CpuPowerCombo" MinWidth="100" Margin="0,0,8,0"
                           SelectionChanged="CpuPower_SelectionChanged"/>
                <Ellipse x:Name="CpuPowerStatusDot" Width="10" Height="10" VerticalAlignment="Center"
                         Fill="#888888" Stroke="#444444" StrokeThickness="0.5" Margin="0,4,0,0"
                         ToolTip="PL1/PL2 写入状态"/>
                <TextBlock x:Name="CpuPowerStatusText" FontSize="11" VerticalAlignment="Center"
                           Margin="4,0,0,0" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           Text="未写入"/>
              </StackPanel>
            </Grid>
          </ui:CardExpander.Header>
          <StackPanel>
            <StackPanel Margin="0,0,0,8">
              <TextBlock FontWeight="DemiBold" FontSize="13" Margin="0,0,0,4">
                <Run Text="{x:Static app:Strings.CpuPowerPL1}"/><Run Text=":"/>
              </TextBlock>
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="150"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ui:NumberBox x:Name="CpuPowerPL1Num" Minimum="1" Maximum="254" SmallChange="1"
                              MaxDecimalPlaces="0" ValueChanged="CpuPowerPL1Num_ValueChanged"
                              Value="{Binding ElementName=CpuPowerPL1Slider, Path=Value, Mode=TwoWay}"/>
                <Slider x:Name="CpuPowerPL1Slider" Grid.Column="1" Minimum="1" Maximum="254"
                        TickFrequency="1" IsSnapToTickEnabled="True" Margin="12,0,0,0"
                        VerticalAlignment="Center"/>
              </Grid>
            </StackPanel>
            <StackPanel>
              <TextBlock FontWeight="DemiBold" FontSize="13" Margin="0,0,0,4">
                <Run Text="{x:Static app:Strings.CpuPowerPL2}"/><Run Text=":"/>
              </TextBlock>
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="150"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ui:NumberBox x:Name="CpuPowerPL2Num" Minimum="1" Maximum="254" SmallChange="1"
                              MaxDecimalPlaces="0" ValueChanged="CpuPowerPL2Num_ValueChanged"
                              Value="{Binding ElementName=CpuPowerPL2Slider, Path=Value, Mode=TwoWay}"/>
                <Slider x:Name="CpuPowerPL2Slider" Grid.Column="1" Minimum="1" Maximum="254"
                        TickFrequency="1" IsSnapToTickEnabled="True" Margin="12,0,0,0"
                        VerticalAlignment="Center"/>
              </Grid>
            </StackPanel>
          </StackPanel>
        </ui:CardExpander>

        <ui:CardExpander Grid.Row="0" Grid.Column="1" Margin="4,0,0,8" x:Name="IccMaxCard"
                         Icon="Gauge24">
          <ui:CardExpander.Header>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="{x:Static app:Strings.IccMaxHeading}" FontWeight="SemiBold"/>
                <TextBlock Text="限制电流峰值。⚠️ 过低降频易死机，过高可能触发保护。" FontSize="12"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,2,0,0"/>
              </StackPanel>
              <ComboBox Grid.Column="1" x:Name="IccMaxCombo" MinWidth="100" VerticalAlignment="Top" Margin="0,0,12,0"
                        SelectionChanged="IccMax_Changed"/>
            </Grid>
          </ui:CardExpander.Header>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="150"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <ui:NumberBox x:Name="IccMaxNum" Minimum="0" Maximum="255" SmallChange="5"
                          MaxDecimalPlaces="0" ValueChanged="IccMaxNum_ValueChanged"
                          Value="{Binding ElementName=IccMaxSlider, Path=Value, Mode=TwoWay}"/>
            <Slider x:Name="IccMaxSlider" Grid.Column="1" Minimum="0" Maximum="255"
                    IsSnapToTickEnabled="True" TickPlacement="BottomRight"
                    Ticks="0,160,165,170,175,180,185,190,195,200,205,210,215,220,225,230,235,240,245,250,255"
                    Margin="12,0,0,0" VerticalAlignment="Center"/>
          </Grid>
        </ui:CardExpander>

        <ui:CardControl Grid.Row="1" Grid.Column="0" Margin="0,0,4,8" x:Name="AcLoadLineCard">
          <ui:CardControl.Header>
              <StackPanel>
                <StackPanel Orientation="Horizontal">
                  <ui:SymbolIcon Symbol="Gauge24" Margin="0,0,6,0"/>
                  <TextBlock Text="{x:Static app:Strings.AcLoadLineHeading}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="调节CPU的电压响应曲线，通常数值越低越好。" FontSize="12"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,2,0,0"/>
                <ComboBox x:Name="AcLoadLineCombo"  Margin="0,8,0,0"
                        SelectionChanged="AcLoadLine_Changed"/>
            </StackPanel>
          </ui:CardControl.Header>
        </ui:CardControl>

        <ui:CardControl Grid.Row="1" Grid.Column="1" Margin="4,0,0,8">
          <ui:CardControl.Header>
            <StackPanel>
              <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Power24" Margin="0,0,6,0"/>
                <TextBlock Text="{x:Static app:Strings.PowerModeHeading}" FontWeight="SemiBold" VerticalAlignment="Center"/>
              </StackPanel>
              <TextBlock Text="调节系统电源策略性能倾向。" FontSize="12"
                         Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,2,0,0"/>
            </StackPanel>
          </ui:CardControl.Header>
          <ComboBox x:Name="PowerModeCombo"  Margin="0,8,0,0"
                    SelectionChanged="PowerMode_SelectionChanged"/>
        </ui:CardControl>

        <ui:CardExpander Grid.Row="2" Grid.Column="0" Margin="0,0,4,8" Icon="Power24">
          <ui:CardExpander.Header>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel>
                <StackPanel Orientation="Horizontal">
                  <ui:SymbolIcon Symbol="Power24" Margin="0,0,6,0"/>
                  <TextBlock Text="{x:Static app:Strings.PowerPlanHeading}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="选择 Windows 系统的电源计划，展开可调节处理器高级电源设置。" FontSize="12"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,2,0,0"/>
              </StackPanel>
              <ComboBox Grid.Column="1" x:Name="PowerPlanCombo" MinWidth="140" VerticalAlignment="Top" Margin="0,0,12,0"
                        SelectionChanged="PowerPlan_SelectionChanged"/>
            </Grid>
          </ui:CardExpander.Header>
          <StackPanel Margin="0,4,0,0">

            <!-- AC/DC and Processor Class toggles -->
            <Grid Margin="0,0,0,12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="电源来源" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"
                         Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
              <ComboBox Grid.Column="1" x:Name="PwrSourceCombo" MinWidth="120" Margin="0,0,16,0"
                        SelectionChanged="PwrSourceCombo_SelectionChanged">
                <ComboBoxItem Content="交流电源 (AC)" Tag="AC" IsSelected="True"/>
                <ComboBoxItem Content="直流电源 (DC)" Tag="DC"/>
              </ComboBox>
              <TextBlock Grid.Column="2" Text="处理器类别" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"
                         Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
              <ComboBox Grid.Column="3" x:Name="PwrClassCombo" MinWidth="140"
                        SelectionChanged="PwrClassCombo_SelectionChanged">
                <ComboBoxItem Content="全部处理器" Tag="0" IsSelected="True"/>
                <ComboBoxItem Content="第一类处理器 (P核)" Tag="1"/>
              </ComboBox>
            </Grid>

            <!-- 1. EPP (Energy Performance Preference) -->
            <StackPanel Margin="0,0,0,10">
              <TextBlock Text="处理器能源性能首选项策略" FontWeight="DemiBold" FontSize="13" Margin="0,0,0,4"/>
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="EppCombo" MinWidth="180" IsEditable="True" Margin="0,0,8,0"
                          SelectionChanged="EppCombo_SelectionChanged"/>
                <TextBlock x:Name="EppCurrentText" Grid.Column="1" Text="-" FontSize="11" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
              </Grid>
              <TextBlock Text="预设：极速响应(0)、偏向性能(20)、平衡(50)、偏向省电(80)、极致省电(100)。可自定义输入 0-100。" FontSize="11"
                         Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- 2. Processor Performance Boost Mode -->
            <StackPanel Margin="0,0,0,10">
              <TextBlock Text="处理器性能提升模式" FontWeight="DemiBold" FontSize="13" Margin="0,0,0,4"/>
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="BoostModeCombo" MinWidth="180" Margin="0,0,8,0"
                          SelectionChanged="BoostModeCombo_SelectionChanged"/>
                <TextBlock x:Name="BoostModeCurrentText" Grid.Column="1" Text="-" FontSize="11" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
              </Grid>
              <TextBlock Text="0=禁用(关闭睿频) / 1=已启用 / 2=高性能 / 3=高效率 / 4=高性能高效率 / 5=积极且有保障 / 6=高效积极且有保障" FontSize="11"
                         Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- 3. Maximum Processor State -->
            <StackPanel Margin="0,0,0,10">
              <TextBlock Text="最大处理器状态" FontWeight="DemiBold" FontSize="13" Margin="0,0,0,4"/>
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="MaxProcStateCombo" MinWidth="180" IsEditable="True" Margin="0,0,8,0"
                          SelectionChanged="MaxProcStateCombo_SelectionChanged"/>
                <TextBlock x:Name="MaxProcStateCurrentText" Grid.Column="1" Text="-" FontSize="11" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
              </Grid>
              <TextBlock Text="预设：100%、99%、95%、90%、85%、80%。可自定义输入 0-100。" FontSize="11"
                         Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- 4. Maximum Processor Frequency -->
            <StackPanel Margin="0,0,0,10">
              <TextBlock Text="处理器最大频率" FontWeight="DemiBold" FontSize="13" Margin="0,0,0,4"/>
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="MaxFreqCombo" MinWidth="180" IsEditable="True" Margin="0,0,8,0"
                          SelectionChanged="MaxFreqCombo_SelectionChanged"/>
                <TextBlock x:Name="MaxFreqCurrentText" Grid.Column="1" Text="-" FontSize="11" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
              </Grid>
              <TextBlock Text="0=不限制(自动)。可自定义输入 MHz 数值。" FontSize="11"
                         Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- 5. SMT Thread Unpark Policy -->
            <StackPanel Margin="0,0,0,10">
              <TextBlock Text="SMT 线程启动策略" FontWeight="DemiBold" FontSize="13" Margin="0,0,0,4"/>
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="SmtPolicyCombo" MinWidth="180" Margin="0,0,8,0"
                          SelectionChanged="SmtPolicyCombo_SelectionChanged"/>
                <TextBlock x:Name="SmtPolicyCurrentText" Grid.Column="1" Text="-" FontSize="11" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
              </Grid>
              <TextBlock Text="0=核心(优先物理核) / 1=每个线程的核心 / 2=循环配置(均衡负载) / 3=顺序" FontSize="11"
                         Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Action buttons -->
            <Grid Margin="0,8,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBlock x:Name="PwrPlanStatus" Grid.Column="0" Text="" FontSize="11" VerticalAlignment="Center"
                         Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
              <ui:Button Grid.Column="1" Content="查看" MinWidth="80" Margin="0,0,8,0"
                         Appearance="Secondary" Click="PwrPlanView_Click"/>
              <ui:Button Grid.Column="2" Content="应用" MinWidth="80"
                         Appearance="Primary" Click="PwrPlanApply_Click"/>
            </Grid>

          </StackPanel>
        </ui:CardExpander>

        <ui:CardControl Grid.Row="2" Grid.Column="1" Margin="4,0,0,8" x:Name="EcoQosCard">
          <ui:CardControl.Header>
            <StackPanel>
              <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="LeafOne24" Margin="0,0,6,0"/>
                <TextBlock Text="{x:Static app:Strings.EcoQosHeading}" FontWeight="SemiBold" VerticalAlignment="Center"/>
              </StackPanel>
              <TextBlock Text="{x:Static app:Strings.PerfEcoQosDesc}" FontSize="12"
                         Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,2,0,0"/>
            </StackPanel>
          </ui:CardControl.Header>
          <StackPanel>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBlock Text="{x:Static app:Strings.EcoQosEnable}" FontSize="12" VerticalAlignment="Center"/>
              <ui:ToggleSwitch x:Name="EcoQosToggle" Grid.Column="1"
                              VerticalAlignment="Center"
                              Checked="EcoQosToggle_Checked" Unchecked="EcoQosToggle_Unchecked"/>
            </Grid>
            <StackPanel x:Name="EcoQosExtra" Margin="0,6,0,0">
              <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{x:Static app:Strings.EcoQosThrottlePlugged}" FontSize="12" VerticalAlignment="Center"/>
                <ui:ToggleSwitch x:Name="EcoQosThrottlePluggedToggle" Grid.Column="1"
                                Checked="EcoQosThrottlePlugged_Changed" Unchecked="EcoQosThrottlePlugged_Changed"/>
              </Grid>
              <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{x:Static app:Strings.EcoQosWhitelist}" FontSize="12" VerticalAlignment="Center"/>
                <ui:Button x:Name="EcoQosWhitelistEdit" Grid.Column="1"
                        MinWidth="60" Height="24" Padding="8,0" Content="{x:Static app:Strings.ButtonEdit}" Click="EcoQosWhitelistEdit_Click" Appearance="Secondary"/>
              </Grid>
              <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{x:Static app:Strings.EcoQosBlacklist}" FontSize="12" VerticalAlignment="Center"/>
                <ui:Button x:Name="EcoQosBlacklistEdit" Grid.Column="1"
                        MinWidth="60" Height="24" Padding="8,0" Content="{x:Static app:Strings.ButtonEdit}" Click="EcoQosBlacklistEdit_Click" Appearance="Secondary"/>
              </Grid>
            </StackPanel>
          </StackPanel>
        </ui:CardControl>

        <!-- 异构调度 (AMD 双CCD 模拟大小核) -->
        <ui:CardExpander Grid.Row="3" Grid.ColumnSpan="2" Margin="{StaticResource CardMargin}" x:Name="HeteroCpuCard"
                         Icon="DeviceEq24">
          <ui:CardExpander.Header>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel>
                <StackPanel Orientation="Horizontal">
                  <ui:SymbolIcon Symbol="DeviceEq24" Margin="0,0,6,0"/>
                  <TextBlock Text="{x:Static app:Strings.HeteroCpuHeading}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="{x:Static app:Strings.HeteroCpuToggleDesc}" FontSize="12"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,2,0,0"/>
              </StackPanel>
              <ui:ToggleSwitch x:Name="HeteroCpuToggle" Grid.Column="1" VerticalAlignment="Top"
                              Checked="HeteroCpuToggle_Changed" Unchecked="HeteroCpuToggle_Changed"/>
            </Grid>
          </ui:CardExpander.Header>
          <StackPanel x:Name="HeteroCpuDetails" Visibility="Collapsed">
            <!-- SmallProcessorMask -->
            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="{x:Static app:Strings.HeteroCpuMaskLabel}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock Text="{x:Static app:Strings.HeteroCpuMaskDesc}" FontSize="10" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
              </StackPanel>
              <TextBox x:Name="HeteroCpuMaskBox" Grid.Column="1" Width="140" Text="FFFF0000"
                       TextChanged="HeteroCpuMask_TextChanged" HorizontalAlignment="Right"/>
            </Grid>
            <!-- CPU info + auto detect -->
            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBlock x:Name="HeteroCpuInfoText" Text="" FontSize="10" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                         VerticalAlignment="Center" TextWrapping="Wrap"/>
              <Button x:Name="HeteroCpuDetectBtn" Grid.Column="1"
                      Content="{x:Static app:Strings.HeteroCpuDetectAuto}"
                      Click="HeteroCpuDetect_Click" Padding="8,2" HorizontalAlignment="Right"/>
            </Grid>
            <!-- DefaultDynamicHeteroCpuPolicy -->
            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="{x:Static app:Strings.HeteroCpuDefaultPolicyLabel}" FontSize="12" FontWeight="SemiBold"/>
                <TextBlock Text="{x:Static app:Strings.HeteroCpuDefaultPolicyDesc}" FontSize="10" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
              </StackPanel>
              <ComboBox x:Name="HeteroCpuDefaultPolicyCombo" Grid.Column="1" MinWidth="120"
                        SelectionChanged="HeteroCpuPolicy_Changed" HorizontalAlignment="Right"/>
            </Grid>
            <!-- DynamicCpuPolicyExpectedRuntime -->
            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="{x:Static app:Strings.HeteroCpuRuntimeLabel}" FontSize="12" FontWeight="SemiBold"/>
                <TextBlock Text="{x:Static app:Strings.HeteroCpuRuntimeDesc}" FontSize="10" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
              </StackPanel>
              <TextBox x:Name="HeteroCpuRuntimeBox" Grid.Column="1" Width="120" Text="1450"
                       TextChanged="HeteroCpuRuntime_Changed" HorizontalAlignment="Right"/>
            </Grid>
            <!-- DynamicHeteroCpuPolicyImportant -->
            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="{x:Static app:Strings.HeteroCpuImportantPolicyLabel}" FontSize="12" FontWeight="SemiBold"/>
                <TextBlock Text="{x:Static app:Strings.HeteroCpuImportantPolicyDesc}" FontSize="10" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
              </StackPanel>
              <ComboBox x:Name="HeteroCpuImportantPolicyCombo" Grid.Column="1" MinWidth="120"
                        SelectionChanged="HeteroCpuPolicy_Changed" HorizontalAlignment="Right"/>
            </Grid>
            <!-- DynamicHeteroCpuPolicyImportantShort -->
            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="{x:Static app:Strings.HeteroCpuImportantShortLabel}" FontSize="12" FontWeight="SemiBold"/>
                <TextBlock Text="{x:Static app:Strings.HeteroCpuImportantShortDesc}" FontSize="10" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
              </StackPanel>
              <ComboBox x:Name="HeteroCpuImportantShortCombo" Grid.Column="1" MinWidth="120"
                        SelectionChanged="HeteroCpuPolicy_Changed" HorizontalAlignment="Right"/>
            </Grid>
            <!-- DynamicHeteroCpuPolicyMask -->
            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel>
