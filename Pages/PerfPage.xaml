                <!-- Row 1: saved values + current state -->
                <TextBlock FontSize="12" Margin="0,0,0,2">
                  <Run Text="{x:Static app:Strings.CoreKeepPriorityLabel}"/><Run x:Name="CoreKeepPriorityText" Text=" -"/>
