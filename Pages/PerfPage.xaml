                          Content="{x:Static app:Strings.ButtonAdd}" Margin="0,0,4,0" Appearance="Secondary" Click="CoreKeepAdd_Click"/>
                  <ui:Button x:Name="CoreKeepSaveBtn" Grid.Column="4" MinWidth="50"
                          Content="{x:Static app:Strings.CoreKeepSaveCurrent}" Margin="0,0,4,0" Appearance="Secondary" Click="CoreKeepSave_Click"/>
                  <ui:Button x:Name="CoreKeepDeleteBtn" Grid.Column="5" MinWidth="40"
                          Content="{x:Static app:Strings.ButtonDelete}" Margin="0,0,0,0" Appearance="Secondary" Click="CoreKeepDelete_Click"/>
