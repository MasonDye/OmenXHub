                          Content="{x:Static app:Strings.CoreKeepBenchmark}" Margin="0,0,0,0" Appearance="Secondary" Click="CoreKeepBenchmark_Click"/>
                </Grid>
              </StackPanel>
            </Grid>
          </ui:CardControl.Header>
        </ui:CardControl>

