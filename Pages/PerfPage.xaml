                                Checked="CoreKeepCoreCheckChanged" Unchecked="CoreKeepCoreCheckChanged"/>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel/>
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                </ItemsControl>

                <!-- Guard config + benchmark -->
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <ui:ToggleSwitch x:Name="CoreKeepGuardToggle" VerticalAlignment="Center" Margin="0,0,4,0"
                                  Checked="CoreKeepGuardToggle_Changed" Unchecked="CoreKeepGuardToggle_Changed"/>
