                  <Run x:Name="CoreKeepLivePriorityText" Text="" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </TextBlock>

                <!-- Row 2: core mode buttons -->
                <Grid Margin="0,0,0,2">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="{x:Static app:Strings.CoreKeepModeLabel}" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                  <ui:Button x:Name="CoreKeepModeAll" Grid.Column="1" MinWidth="40" Content="{x:Static app:Strings.CoreKeepModeAll}" FontSize="11"
                          Margin="0,0,4,0" Appearance="Primary" Click="CoreKeepMode_Click" Tag="All"/>
                  <ui:Button x:Name="CoreKeepModeAuto" Grid.Column="2" MinWidth="40" Content="{x:Static app:Strings.CoreKeepModeAuto}" FontSize="11"
                          Margin="0,0,4,0" Appearance="Secondary" Click="CoreKeepMode_Click" Tag="Auto"/>
                  <ui:Button x:Name="CoreKeepModeManual" Grid.Column="3" MinWidth="40" Content="{x:Static app:Strings.CoreKeepModeManual}" FontSize="11"
                          Margin="0,0,0,0" Appearance="Secondary" Click="CoreKeepMode_Click" Tag="Manual"/>
                </Grid>

                <!-- Row 3: priority selection -->
