              <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <ui:ToggleSwitch x:Name="AdlxEnhancedSyncToggle" Margin="0,0,8,0" VerticalAlignment="Center"
                                 Checked="AdlxEnhancedSync_Changed" Unchecked="AdlxEnhancedSync_Changed"/>
                <TextBlock Grid.Column="1" Text="Enhanced Sync" FontSize="12" VerticalAlignment="Center"/>
              </Grid>
              <!-- Boost -->
              <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ui:ToggleSwitch x:Name="AdlxBoostToggle" VerticalAlignment="Center" Margin="0,0,8,0"
                                 Checked="AdlxBoost_Changed" Unchecked="AdlxBoost_Changed"/>
                <TextBlock Grid.Column="1" Text="Boost" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Grid.Column="2" Text="(%)" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ui:NumberBox x:Name="AdlxBoostNum" Grid.Column="3" Minimum="-20" Maximum="20" SmallChange="1" MaxDecimalPlaces="0" MinWidth="60"
                              ValueChanged="AdlxBoost_Changed"/>
              </Grid>
              <!-- Image Sharpening -->
              <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ui:ToggleSwitch x:Name="AdlxImageSharpToggle" VerticalAlignment="Center" Margin="0,0,8,0"
                                 Checked="AdlxImageSharp_Changed" Unchecked="AdlxImageSharp_Changed"/>
                <TextBlock Grid.Column="1" Text="Image Sharpening" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Grid.Column="2" Text="(%)" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ui:NumberBox x:Name="AdlxImageSharpNum" Grid.Column="3" Minimum="0" Maximum="100" SmallChange="1" MaxDecimalPlaces="0" MinWidth="60"
                              ValueChanged="AdlxImageSharp_Changed"/>
              </Grid>
              <TextBlock x:Name="AdlxStatus" FontSize="11" Margin="0,4,0,0"
                         Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
            </StackPanel>
          </ui:CardControl.Header>
        </ui:CardControl>

        <!-- RTSS Frame Limit -->
        <ui:CardExpander Grid.Row="1" Grid.Column="0" Margin="0,0,4,8" x:Name="RtssCard" Visibility="Collapsed"
                         Icon="Fps6024">
          <ui:CardExpander.Header>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="{x:Static app:Strings.RtssHeading}" FontWeight="SemiBold"/>
                <TextBlock Text="{x:Static app:Strings.RtssDesc}" FontSize="12"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,2,0,0"/>
              </StackPanel>
              <ui:ToggleSwitch x:Name="RtssMasterToggle" Grid.Column="1" VerticalAlignment="Top"
                              Checked="RtssMasterToggle_Changed" Unchecked="RtssMasterToggle_Changed"/>
            </Grid>
          </ui:CardExpander.Header>
          <StackPanel>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <ui:NumberBox x:Name="RtssNum" Minimum="0" Maximum="999" SmallChange="1"
                            MaxDecimalPlaces="0" ValueChanged="RtssNum_ValueChanged"
                            Value="{Binding ElementName=RtssSlider, Path=Value, Mode=TwoWay}"/>
              <Slider x:Name="RtssSlider" Grid.Column="1" Minimum="0" Maximum="999"
                      TickFrequency="1" Margin="12,0,0,0" VerticalAlignment="Center"/>
            </Grid>
            <TextBlock x:Name="RtssStatus" FontSize="11" Margin="0,4,0,0"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
          </StackPanel>
        </ui:CardExpander>

        <!-- iGPU Power Limit (PawnIO MSR) -->
        <ui:CardExpander Grid.Row="2" Grid.Column="0" Margin="0,0,4,8" x:Name="PawnIgpuPowerCard" Icon="Power24">
          <ui:CardExpander.Header>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="iGPU 功耗墙 (MSR 0x621)" FontWeight="SemiBold"/>
                <TextBlock Text="直写GT VR功率限制，解锁iGPU功耗上限。" FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,2,0,0"/>
              </StackPanel>
              <ui:ToggleSwitch x:Name="PawnIgpuPowerMasterToggle" Grid.Column="1" VerticalAlignment="Top"
                              Checked="PawnIgpuPowerMasterToggle_Changed" Unchecked="PawnIgpuPowerMasterToggle_Changed"/>
            </Grid>
          </ui:CardExpander.Header>
          <StackPanel>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <ui:NumberBox x:Name="PawnIgpuPowerNum" Minimum="0" Maximum="4095" SmallChange="1" MaxDecimalPlaces="0" ValueChanged="PawnIgpuPowerNum_ValueChanged"
                            Value="{Binding ElementName=PawnIgpuPowerSlider, Path=Value, Mode=TwoWay}"/>
              <Slider x:Name="PawnIgpuPowerSlider" Grid.Column="1" Minimum="0" Maximum="4095" TickFrequency="1" Margin="12,0,0,0" VerticalAlignment="Center"/>
            </Grid>
            <TextBlock x:Name="PawnIgpuPowerStatus" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,4,0,0"/>
          </StackPanel>
        </ui:CardExpander>

        <!-- iGPU Max Ratio (PawnIO MSR) -->
        <ui:CardExpander Grid.Row="2" Grid.Column="1" Margin="4,0,0,8" x:Name="PawnIgpuRatioCard" Icon="Clock24">
          <ui:CardExpander.Header>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="iGPU 最大倍频 (MSR 0x1A2)" FontWeight="SemiBold"/>
                <TextBlock Text="调节iGPU最高运行频率。8=800MHz, 60=6000MHz。⚠️ 过高可能死机。" FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,2,0,0"/>
              </StackPanel>
              <ui:ToggleSwitch x:Name="PawnIgpuRatioMasterToggle" Grid.Column="1" VerticalAlignment="Top"
                              Checked="PawnIgpuRatioMasterToggle_Changed" Unchecked="PawnIgpuRatioMasterToggle_Changed"/>
            </Grid>
          </ui:CardExpander.Header>
          <StackPanel>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <ui:NumberBox x:Name="PawnIgpuRatioNum" Minimum="8" Maximum="60" SmallChange="1" MaxDecimalPlaces="0" ValueChanged="PawnIgpuRatioNum_ValueChanged"
                            Value="{Binding ElementName=PawnIgpuRatioSlider, Path=Value, Mode=TwoWay}"/>
              <Slider x:Name="PawnIgpuRatioSlider" Grid.Column="1" Minimum="8" Maximum="60" TickFrequency="1" IsSnapToTickEnabled="True" Margin="12,0,0,0" VerticalAlignment="Center"/>
            </Grid>
            <TextBlock x:Name="PawnIgpuRatioStatus" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,4,0,0"/>
          </StackPanel>
        </ui:CardExpander>

        <!-- iGPU Clock Override (AMD APU SMU) — moved from CpuAdvGrid -->
        <ui:CardExpander Grid.Row="3" Grid.Column="0" Margin="0,0,4,8" x:Name="ApuGfxClkCard" Visibility="Collapsed"
                         Icon="Clock24">
          <ui:CardExpander.Header>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="iGPU 时钟覆盖 (SMU)" FontWeight="SemiBold"/>
                <TextBlock Text="强制设定 iGPU 运行频率 (gfx-clk)。0=自动。" FontSize="12"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,2,0,0"/>
              </StackPanel>
              <ui:ToggleSwitch x:Name="ApuGfxClkMasterToggle" Grid.Column="1" VerticalAlignment="Top"
                              Checked="ApuGfxClkMasterToggle_Changed" Unchecked="ApuGfxClkMasterToggle_Changed"/>
            </Grid>
          </ui:CardExpander.Header>
          <StackPanel>
            <Grid>
              <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
              <ui:NumberBox x:Name="ApuGfxClkNum" Minimum="0" Maximum="2200" SmallChange="50" MaxDecimalPlaces="0" ValueChanged="ApuGfxClkNum_ValueChanged"
                            Value="{Binding ElementName=ApuGfxClkSlider, Path=Value, Mode=TwoWay}"/>
              <Slider x:Name="ApuGfxClkSlider" Grid.Column="1" Minimum="0" Maximum="2200" TickFrequency="50" IsSnapToTickEnabled="True" Margin="12,0,0,0" VerticalAlignment="Center"/>
            </Grid>
            <TextBlock x:Name="ApuGfxClkStatus" FontSize="11" Margin="0,4,0,0" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
          </StackPanel>
        </ui:CardExpander>

      </Grid>

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
        <ui:Button x:Name="btnPerfUndo" Height="36" MinWidth="44" Margin="0,0,6,0" ToolTip="恢复默认预设并清空自定义预设" Click="btnPerfUndo_Click" Appearance="Danger">
          <StackPanel Orientation="Horizontal">
            <ui:SymbolIcon Symbol="ArrowReset24" FontSize="14" Margin="0,0,4,0"/>
            <TextBlock VerticalAlignment="Center">恢复</TextBlock>
          </StackPanel>
        </ui:Button>
        <ui:Button x:Name="btnPerfLoad" Height="36" MinWidth="44" Margin="0,0,6,0" ToolTip="重新加载当前预设的值" Click="btnPerfLoad_Click" Appearance="Secondary">
          <StackPanel Orientation="Horizontal">
            <ui:SymbolIcon Symbol="ArrowClockwise24" FontSize="14" Margin="0,0,4,0"/>
            <TextBlock VerticalAlignment="Center">加载</TextBlock>
          </StackPanel>
        </ui:Button>
        <ui:Button x:Name="btnPerfDelete" Height="36" MinWidth="44" Margin="0,0,6,0" ToolTip="删除当前预设" Click="btnPerfDelete_Click" Appearance="Secondary">
          <StackPanel Orientation="Horizontal">
            <ui:SymbolIcon Symbol="Delete24" FontSize="14" Margin="0,0,4,0"/>
            <TextBlock VerticalAlignment="Center">删除</TextBlock>
          </StackPanel>
        </ui:Button>
        <ui:Button x:Name="btnPerfSave" Height="36" MinWidth="44" Margin="0,0,0,0" ToolTip="保存当前设置为新预设并应用" Click="btnPerfSave_Click" Appearance="Primary">
          <StackPanel Orientation="Horizontal">
            <ui:SymbolIcon Symbol="Save24" FontSize="14" Margin="0,0,4,0"/>
            <TextBlock VerticalAlignment="Center">保存</TextBlock>
          </StackPanel>
        </ui:Button>
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</Page>
