                  <TextBlock Text="{x:Static app:Strings.CoreKeepPriorityLabel}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                  <ComboBox x:Name="CoreKeepPriorityCombo" Grid.Column="1" Height="32" MaxDropDownHeight="200"
